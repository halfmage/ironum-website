---
import { Image } from 'astro:assets';
import checkmarkIcon from '../../public/checkmark-icon.svg';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const locale = getLangFromUrl(Astro.url);
const t = useTranslations(locale);
---

<section id="usecases" class="px-4 md:px-20 py-20 md:py-32 space-y-8 md:space-y-16 max-w-7xl mx-auto">
  <h2 class="text-3xl md:text-5xl xl:text-7xl font-bold">{t.useCases.title}</h2>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
    {t.useCases.items.map(item => (
      <div class="flex gap-4 md:gap-8 items-center">
        <div class="bg-blue-600 rounded-2xl p-4 md:p-6 flex items-center justify-center shrink-0">
          <Image src={checkmarkIcon} alt="" class="size-8 md:size-10" width={40} height={40} loading="lazy" />
        </div>
        <div>
          <h3 class="text-2xl font-bold mb-2">{item.title}</h3>
          <p class="text-gray-500 text-lg font-semibold">{item.description}</p>
        </div>
      </div>
    ))}
  </div>
</section>
