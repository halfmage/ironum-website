          <li><a href="/services/llm-fine-tuning/" class="text-white/60 hover:text-white text-sm transition-colors">LLM Fine-Tuning</a></li>
          <li><a href="/services/geo-optimization/" class="text-white/60 hover:text-white text-sm transition-colors">GEO Optimization</a></li>
        </ul>
      </div>
      <div>
        <h4 class="font-bold text-sm uppercase tracking-wider mb-4">Industries</h4>
        <ul class="space-y-2">
          <li><a href="/industries/legal/" class="text-white/60 hover:text-white text-sm transition-colors">Legal</a></li>
          <li><a href="/industries/manufacturing/" class="text-white/60 hover:text-white text-sm transition-colors">Manufacturing</a></li>
          <li><a href="/industries/financial-services/" class="text-white/60 hover:text-white text-sm transition-colors">Financial Services</a></li>
          <li><a href="/industries/education/" class="text-white/60 hover:text-white text-sm transition-colors">Education</a></li>
