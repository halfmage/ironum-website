      <div>
        <h4 class="font-bold text-sm uppercase tracking-wider mb-4">Resources</h4>
        <ul class="space-y-2">
          <li><a href="/resources/blog/" class="text-white/60 hover:text-white text-sm transition-colors">Blog</a></li>
          <li><a href="/platform/" class="text-white/60 hover:text-white text-sm transition-colors">Platform</a></li>
          <li><a href="/platform/deployment/" class="text-white/60 hover:text-white text-sm transition-colors">Deployment Options</a></li>
