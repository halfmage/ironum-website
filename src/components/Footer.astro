---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const locale = getLangFromUrl(Astro.url);
const t = useTranslations(locale);
---

<footer class="w-full bg-black text-white">
  <div class="max-w-7xl mx-auto px-4 md:px-20 py-16 md:py-20">
    <!-- Newsletter Signup -->
    <div class="pb-12 mb-12 border-b border-white/10">
      <div class="max-w-2xl">
        <h3 class="text-xl font-bold mb-2">{t.footer.newsletter.title}</h3>
        <p class="text-white/60 text-sm mb-6">{t.footer.newsletter.description}</p>
        <form name={t.footer.newsletter.formName} method="POST" data-netlify="true" netlify-honeypot="bot-field" class="flex flex-col sm:flex-row gap-3">
          <input type="hidden" name="form-name" value={t.footer.newsletter.formName}>
          <input name="bot-field" class="hidden">
          <input type="email" name="email" required placeholder={t.footer.newsletter.placeholder} class="flex-1 bg-white/10 border border-white/20 rounded-full px-5 py-3 text-white placeholder-white/40 text-sm focus:outline-none focus:border-white/40 transition-colors">
          <button type="submit" class="bg-blue-600 text-white rounded-full px-6 py-3 font-medium text-sm hover:bg-blue-700 transition-all duration-200 min-h-[48px] touch-manipulation whitespace-nowrap">{t.footer.newsletter.button}</button>
        </form>
      </div>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-12">
      <div>
        <h4 class="font-bold text-sm uppercase tracking-wider mb-4">{t.footer.servicesTitle}</h4>
        <ul class="space-y-2">
          {t.footer.serviceLinks.map(link => (
            <li><a href={link.href} class="text-white/60 hover:text-white text-sm transition-colors">{link.name}</a></li>
          ))}
        </ul>
      </div>
      <div>
        <h4 class="font-bold text-sm uppercase tracking-wider mb-4">{t.footer.industriesTitle}</h4>
        <ul class="space-y-2">
          {t.footer.industryLinks.map(link => (
            <li><a href={link.href} class="text-white/60 hover:text-white text-sm transition-colors">{link.name}</a></li>
          ))}
        </ul>
      </div>
      <div>
        <h4 class="font-bold text-sm uppercase tracking-wider mb-4">{t.footer.resourcesTitle}</h4>
        <ul class="space-y-2">
          {t.footer.resourceLinks.map(link => (
            <li><a href={link.href} class="text-white/60 hover:text-white text-sm transition-colors">{link.name}</a></li>
          ))}
        </ul>
      </div>
      <div>
        <h4 class="font-bold text-sm uppercase tracking-wider mb-4">{t.footer.companyTitle}</h4>
        <ul class="space-y-2">
          {t.footer.companyLinks.map(link => (
            <li><a href={link.href} class="text-white/60 hover:text-white text-sm transition-colors">{link.name}</a></li>
          ))}
        </ul>
      </div>
    </div>
    <div class="border-t border-white/10 mt-12 pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-white/40 text-sm">{t.footer.copyright}</p>
      <p class="text-white/40 text-sm">{t.footer.location}</p>
    </div>
  </div>
</footer>
