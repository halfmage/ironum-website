---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const locale = getLangFromUrl(Astro.url);
const t = useTranslations(locale);
---

<footer class="w-full bg-black text-white">
  <div class="max-w-7xl mx-auto px-4 md:px-20 py-16 md:py-20">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-12">
      <div>
        <h4 class="font-bold text-sm uppercase tracking-wider mb-4">{t.footer.servicesTitle}</h4>
        <ul class="space-y-2">
          {t.footer.serviceLinks.map(link => (
            <li><a href={link.href} class="text-white/60 hover:text-white text-sm transition-colors">{link.name}</a></li>
          ))}
        </ul>
      </div>
      <div>
        <h4 class="font-bold text-sm uppercase tracking-wider mb-4">{t.footer.industriesTitle}</h4>
        <ul class="space-y-2">
          {t.footer.industryLinks.map(link => (
            <li><a href={link.href} class="text-white/60 hover:text-white text-sm transition-colors">{link.name}</a></li>
          ))}
        </ul>
      </div>
      <div>
        <h4 class="font-bold text-sm uppercase tracking-wider mb-4">{t.footer.resourcesTitle}</h4>
        <ul class="space-y-2">
          {t.footer.resourceLinks.map(link => (
            <li><a href={link.href} class="text-white/60 hover:text-white text-sm transition-colors">{link.name}</a></li>
          ))}
        </ul>
      </div>
      <div>
        <h4 class="font-bold text-sm uppercase tracking-wider mb-4">{t.footer.companyTitle}</h4>
        <ul class="space-y-2">
          {t.footer.companyLinks.map(link => (
            <li><a href={link.href} class="text-white/60 hover:text-white text-sm transition-colors">{link.name}</a></li>
          ))}
        </ul>
      </div>
    </div>
    <div class="border-t border-white/10 mt-12 pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-white/40 text-sm">{t.footer.copyright}</p>
      <p class="text-white/40 text-sm">{t.footer.location}</p>
    </div>
  </div>
</footer>
