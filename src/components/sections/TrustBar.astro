---
export interface Props {
  title?: string;
}

const { title = "Built on trusted, enterprise-grade technology" } = Astro.props;
---

<section class="px-4 md:px-20 py-12 md:py-16 border-y border-gray-100">
  <div class="max-w-7xl mx-auto">
    <p class="text-center text-gray-400 text-sm font-semibold uppercase tracking-[0.2em] mb-8">{title}</p>
    <div class="flex flex-wrap justify-center items-center gap-8 md:gap-16">
      <div class="flex items-center gap-2 text-gray-400">
        <span class="text-lg font-bold">n8n</span>
      </div>
      <div class="flex items-center gap-2 text-gray-400">
        <span class="text-lg font-bold">Hetzner</span>
      </div>
      <div class="flex items-center gap-2 text-gray-400">
        <span class="text-lg font-bold">Microsoft Azure</span>
      </div>
      <div class="flex items-center gap-2 text-gray-400">
        <span class="text-lg font-bold">OpenAI</span>
      </div>
      <div class="flex items-center gap-2 text-gray-400">
        <span class="text-lg font-bold">Anthropic</span>
      </div>
      <div class="flex items-center gap-2 text-gray-400">
        <span class="text-lg font-bold">GDPR</span>
      </div>
      <div class="flex items-center gap-2 text-gray-400">
        <span class="text-lg font-bold">EU AI Act</span>
      </div>
    </div>
  </div>
</section>
