---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const locale = getLangFromUrl(Astro.url);
const t = useTranslations(locale);
---

<section class="px-4 md:px-20 py-20 md:py-32">
  <div class="max-w-7xl mx-auto space-y-12">
    <div class="text-center space-y-4">
      <span class="text-orange-500 font-semibold tracking-[0.2em] text-sm uppercase block">{t.testimonials.eyebrow}</span>
      <h2 class="text-3xl md:text-5xl xl:text-7xl font-bold">{t.testimonials.title}</h2>
      <p class="text-gray-500 text-lg font-semibold max-w-2xl mx-auto">{t.testimonials.subtitle}</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 pt-8">
      {t.testimonials.items.map(item => (
        <a href={item.href} class="border-2 border-gray-100 rounded-2xl p-8 flex flex-col justify-between hover:border-blue-600 transition-all duration-200 no-underline">
          <div>
            <span class="inline-block bg-orange-500/10 text-orange-500 text-xs font-semibold uppercase tracking-wider px-3 py-1 rounded-full mb-4">{item.badge}</span>
            <blockquote class="text-gray-700 text-base leading-relaxed mb-6">{item.quote}</blockquote>
          </div>
          <div class="flex items-center gap-4 pt-4 border-t border-gray-100">
            <img src={item.avatar} alt={item.name} class="w-12 h-12 rounded-full object-cover" width="48" height="48" loading="lazy" />
            <div>
              <p class="font-bold text-gray-900">{item.name}</p>
              <p class="text-gray-500 text-sm">{item.role}</p>
            </div>
          </div>
          <div class="mt-6 rounded-xl overflow-hidden border border-gray-100">
            <img src={item.screenshot} alt={item.screenshotAlt} class="w-full h-auto" loading="lazy" />
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
