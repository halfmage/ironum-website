---
import '../styles/global.css';
import { getLangFromUrl, useTranslations, type Locale } from '../i18n/utils';
import { getAlternateUrl } from '../i18n/routes';

export interface BreadcrumbItem {
  label: string;
  href: string;
}

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  breadcrumbs?: BreadcrumbItem[];
  structuredData?: object[];
  locale?: Locale;
  preloadImage?: string;
  noindex?: boolean;
}

const locale = Astro.props.locale || getLangFromUrl(Astro.url);
const t = useTranslations(locale);

const {
  title = t.meta.defaultTitle,
  description = t.meta.defaultDescription,
  ogImage = "/social.png",
  ogType = "website",
  breadcrumbs,
  structuredData,
  preloadImage,
  noindex = false,
} = Astro.props;

const canonicalUrl = `https://ironum.com${Astro.url.pathname}`;
const currentPath = Astro.url.pathname;
const enPath = locale === 'en' ? currentPath : getAlternateUrl(currentPath, 'de');
const dePath = locale === 'de' ? currentPath : getAlternateUrl(currentPath, 'en');
const enUrl = enPath ? `https://ironum.com${enPath}` : null;
const deUrl = dePath ? `https://ironum.com${dePath}` : null;
const alternateUrl = locale === 'de' ? enUrl : deUrl;
const ogLocale = locale === 'de' ? 'de_DE' : 'en_US';
const ogLocaleAlt = locale === 'de' ? 'en_US' : 'de_DE';

const defaultStructuredData = [
  {
    "@type": ["Organization", "ProfessionalService"],
    "@id": "https://ironum.com/#organization",
    "name": "Ironum",
    "legalName": "LearnSlice UG (haftungsbeschränkt)",
    "url": "https://ironum.com",
    "logo": {
      "@type": "ImageObject",
      "url": "https://ironum.com/ironum-logo.svg",
      "width": 120,
      "height": 24
    },
    "description": "Full-service AI development partner for European businesses. We build enterprise RAG, workflow automation, chatbots, and custom AI solutions. GDPR compliant, deployed on your infrastructure.",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Luisenstraße 66",
      "postalCode": "40215",
      "addressLocality": "Düsseldorf",
      "addressCountry": "DE"
    },
    "contactPoint": {
      "@type": "ContactPoint",
      "telephone": "+49-15758539892",
      "email": "info@ironum.com",
      "contactType": "customer service",
      "availableLanguage": ["English", "German"]
    },
    "foundingDate": "2024",
    "areaServed": [
      { "@type": "Place", "name": "Europe" },
      { "@type": "Country", "name": "United States" }
    ],
    "sameAs": [
      "https://www.linkedin.com/company/ironum",
      "https://askmention.com/"
    ],
    "founder": { "@id": "https://ironum.com/#person-gerrit" }
  },
  {
    "@type": "Person",
    "@id": "https://ironum.com/#person-gerrit",
    "name": "Gerrit Halfmann",
    "jobTitle": "Founder",
    "worksFor": { "@id": "https://ironum.com/#organization" },
    "image": "https://ironum.com/gerrit-halfmann.jpg",
    "description": "Creative technologist and web designer with 20+ years of experience. Founder of Ironum, LearnSlice (AI-powered education platform), and AskMention (Generative Engine Optimization tool). Focused on GDPR-compliant AI deployment for European enterprises.",
    "knowsAbout": [
      "Generative AI",
      "Retrieval-Augmented Generation",
      "EU AI Act compliance",
      "GDPR",
      "European AI sovereignty",
      "On-premise AI deployment",
      "Open-source LLMs"
    ],
    "sameAs": [
      "https://www.linkedin.com/in/gerrit-halfmann/",
      "https://askmention.com/"
    ]
  },
  {
    "@type": "WebSite",
    "@id": "https://ironum.com/#website",
    "url": "https://ironum.com",
    "name": "Ironum AI Core",
    "description": "Full-service AI development partner for European businesses.",
    "publisher": { "@id": "https://ironum.com/#organization" },
    "inLanguage": locale === 'de' ? 'de-DE' : 'en-US'
  }
];

const allStructuredData = [...defaultStructuredData, ...(structuredData ?? [])];

const breadcrumbSchema = breadcrumbs ? {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": breadcrumbs.map((item, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "name": item.label,
    "item": `https://ironum.com${item.href}`
  }))
} : null;
---

<!DOCTYPE html>
<html lang={locale === 'de' ? 'de' : 'en'}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.png" type="image/x-icon" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, 'https://ironum.com').href} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content={ogType} />
    <meta property="og:locale" content={ogLocale} />
    {alternateUrl && <meta property="og:locale:alternate" content={ogLocaleAlt} />}
    <meta property="og:site_name" content="Ironum" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, 'https://ironum.com').href} />

    <meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow"} />

    {preloadImage && <link rel="preload" href={preloadImage} as="image" fetchpriority="high" />}
    <link rel="dns-prefetch" href="//outlook.office.com" />

    <link rel="canonical" href={canonicalUrl} />
    {enUrl && <link rel="alternate" hreflang="en" href={enUrl} />}
    {deUrl && <link rel="alternate" hreflang="de" href={deUrl} />}
    {enUrl && <link rel="alternate" hreflang="x-default" href={enUrl} />}

    <script type="application/ld+json" set:html={JSON.stringify({ "@context": "https://schema.org", "@graph": allStructuredData })} />
    {breadcrumbSchema && <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />}
  </head>
  <body class="bg-white text-black">
    <slot />
    <script is:inline data-collect-dnt="true" async src="https://scripts.simpleanalyticscdn.com/latest.js"></script>
  </body>
</html>
