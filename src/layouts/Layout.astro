---
import '../styles/global.css';

export interface BreadcrumbItem {
  label: string;
  href: string;
}

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  breadcrumbs?: BreadcrumbItem[];
  structuredData?: object[];
}

const {
  title = "Ironum | Enterprise AI Without the Compliance Risk",
  description = "European AI engineering partner. Private AI systems deployed on your infrastructure. GDPR compliant. No vendor lock-in. Book a free strategy call.",
  ogImage = "/social.png",
  breadcrumbs,
  structuredData,
} = Astro.props;

const canonicalUrl = `https://www.ironum.com${Astro.url.pathname}`;

const defaultStructuredData = [
  {
    "@type": "Organization",
    "@id": "https://www.ironum.com/#organization",
    "name": "Ironum",
    "legalName": "LearnSlice UG (haftungsbeschränkt)",
    "url": "https://www.ironum.com",
    "logo": {
      "@type": "ImageObject",
      "url": "https://www.ironum.com/ironum-logo.svg",
      "width": 120,
      "height": 24
    },
    "description": "Full-service AI development partner for European businesses. We build enterprise RAG, workflow automation, chatbots, and custom AI solutions. GDPR compliant, deployed on your infrastructure.",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Luisenstraße 66",
      "postalCode": "40215",
      "addressLocality": "Düsseldorf",
      "addressCountry": "DE"
    },
    "contactPoint": {
      "@type": "ContactPoint",
      "telephone": "+49-15758539892",
      "email": "info@ironum.com",
      "contactType": "customer service",
      "availableLanguage": ["English", "German"]
    },
    "foundingDate": "2024",
    "areaServed": { "@type": "Place", "name": "Europe" }
  },
  {
    "@type": "WebSite",
    "@id": "https://www.ironum.com/#website",
    "url": "https://www.ironum.com",
    "name": "Ironum AI Core",
    "description": "Full-service AI development partner for European businesses.",
    "publisher": { "@id": "https://www.ironum.com/#organization" },
    "inLanguage": "en-US"
  }
];

const allStructuredData = structuredData || defaultStructuredData;

const breadcrumbSchema = breadcrumbs ? {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": breadcrumbs.map((item, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "name": item.label,
    "item": `https://www.ironum.com${item.href}`
  }))
} : null;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.png" type="image/x-icon" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, 'https://www.ironum.com').href} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content="Ironum" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, 'https://www.ironum.com').href} />

    <meta name="robots" content="index, follow" />

    <link rel="preload" href="/ironum-logo.svg" as="image" type="image/svg+xml" />
    <link rel="dns-prefetch" href="//outlook.office.com" />

    <link rel="canonical" href={canonicalUrl} />

    <script type="application/ld+json" set:html={JSON.stringify({ "@context": "https://schema.org", "@graph": allStructuredData })} />
    {breadcrumbSchema && <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />}
  </head>
  <body class="bg-white text-black">
    <slot />
    <script is:inline data-collect-dnt="true" async src="https://scripts.simpleanalyticscdn.com/latest.js"></script>
  </body>
</html>
