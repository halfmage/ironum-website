---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Hero from '../components/Hero.astro';
import ServiceCard from '../components/cards/ServiceCard.astro';
import IndustryCard from '../components/cards/IndustryCard.astro';
import Infrastructure from '../components/Infrastructure.astro';
import Impacts from '../components/Impacts.astro';
import ProcessSteps from '../components/sections/ProcessSteps.astro';
import FinalCTA from '../components/FinalCTA.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <Navigation />
  <Hero />

  <!-- Trusted By -->
  <section class="px-4 md:px-20 py-12 md:py-16 border-b border-gray-100">
    <div class="max-w-7xl mx-auto">
      <p class="text-center text-gray-400 text-sm font-semibold uppercase tracking-[0.2em] mb-8">Trusted by</p>
      <div class="flex flex-wrap justify-center items-center gap-10 md:gap-16">
        <img src="/logos/learnslice.png" alt="LearnSlice" class="h-20 max-w-[200px] w-auto object-contain" loading="lazy" />
        <img src="/logos/fh-dortmund.svg" alt="FH Dortmund" class="h-12 max-w-[180px] w-auto object-contain" loading="lazy" />
        <img src="/logos/smella.png" alt="Smella" class="h-12 max-w-[160px] w-auto object-contain" loading="lazy" />
        <img src="/logos/ute-becker.svg" alt="Ute Becker Nutrition Consulting" class="h-12 max-w-[180px] w-auto object-contain" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- The Problem -->
  <section class="px-4 md:px-20 py-20 md:py-32">
    <div class="max-w-7xl mx-auto space-y-8">
      <span class="text-orange-500 font-semibold tracking-[0.2em] text-sm uppercase block">THE PROBLEM</span>
      <h2 class="text-3xl md:text-5xl xl:text-7xl font-bold">European Companies Are Stuck in an AI Catch-22</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 pt-4">
        <div class="border-2 border-gray-100 rounded-2xl p-6 md:p-8">
          <h3 class="text-2xl font-bold mb-3">"We want to use AI..."</h3>
          <p class="text-gray-500 text-lg font-semibold">Your competitors are shipping AI features monthly. Your team sees the potential. Leadership is asking when you'll catch up.</p>
        </div>
        <div class="border-2 border-gray-100 rounded-2xl p-6 md:p-8">
          <h3 class="text-2xl font-bold mb-3">"...but we can't risk our data."</h3>
          <p class="text-gray-500 text-lg font-semibold">Every AI vendor wants your data in their cloud. Your legal team says no. Your DPO says no. GDPR says no. And the EU AI Act deadline is 4 months away.</p>
        </div>
        <div class="border-2 border-gray-100 rounded-2xl p-6 md:p-8">
          <h3 class="text-2xl font-bold mb-3">"So nothing happens."</h3>
          <p class="text-gray-500 text-lg font-semibold">Promising AI pilots stall in legal review. Teams go back to manual work. The gap between you and AI-native competitors grows wider every quarter.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Overview -->
  <section class="px-4 md:px-20 py-20 md:py-32 max-w-7xl mx-auto space-y-8">
    <span class="text-orange-500 font-semibold tracking-[0.2em] text-sm uppercase block">WHAT WE BUILD FOR YOU</span>
    <h2 class="text-3xl md:text-5xl xl:text-7xl font-bold">Six Ways We Put AI to Work in Your Business</h2>
    <p class="text-gray-500 text-lg font-semibold max-w-2xl">Each solution runs on your infrastructure, stays GDPR compliant, and is production-ready in weeks, not months.</p>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 pt-4">
      <ServiceCard title="AI Strategy & Audits" description="Find out exactly where AI will save you time and money, and what it takes to get there compliantly." href="/services/ai-consulting/" />
      <ServiceCard title="Workflow Automation" description="Eliminate manual data entry, approvals, and reporting with 400+ automated integrations. No vendor lock-in." href="/services/workflow-automation/" />
      <ServiceCard title="Private Knowledge Search" description="Your team asks questions, AI finds answers across all your documents instantly, on your servers." href="/services/enterprise-rag/" />
      <ServiceCard title="AI Assistants & Chatbots" description="Deploy customer-facing and internal AI assistants that know your business: branded, private, multi-channel." href="/services/chatbot-interfaces/" />
      <ServiceCard title="Custom AI Models" description="AI trained specifically on your industry data. Your model. Your servers. No per-query API costs." href="/services/llm-fine-tuning/" />
      <ServiceCard title="AI Search Visibility" description="Get your brand recommended by ChatGPT, Perplexity, and AI-powered search engines." href="/services/geo-optimization/" />
    </div>
  </section>

  <!-- Industry Solutions -->
  <section class="px-4 md:px-20 py-20 md:py-32 bg-gray-50">
    <div class="max-w-7xl mx-auto space-y-8">
      <span class="text-orange-500 font-semibold tracking-[0.2em] text-sm uppercase block">INDUSTRIES</span>
      <h2 class="text-3xl md:text-5xl xl:text-7xl font-bold">Built for Your Industry</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 pt-4">
        <IndustryCard title="Legal" description="GDPR-compliant contract review and compliance automation." href="/industries/legal/" stat="61% of lawyers use AI, but only 14% have specialized tools" />
        <IndustryCard title="Manufacturing" description="Industry 4.0 AI for production, quality, and maintenance." href="/industries/manufacturing/" stat="34.6% CAGR, EUR 5.5B German government support" />
        <IndustryCard title="Financial Services" description="Data-driven advisory with full data sovereignty." href="/industries/financial-services/" stat="Moving from AI exploration to implementation" />
        <IndustryCard title="Education" description="LearnSlice AI Mentor for training, exams, and onboarding." href="/industries/education/" stat="EUR 2.11B market. Germany leads with 30.1% share" />
        <IndustryCard title="Healthcare" description="Administrative AI that keeps patient data on your servers." href="/industries/healthcare/" stat="Fastest-growing AI vertical in Europe" />
        <IndustryCard title="Public Sector" description="Sovereign AI for citizen services and document processing." href="/industries/public-sector/" stat="245 AI initiatives across 21 European countries" />
      </div>
    </div>
  </section>

  <Impacts />
  <Infrastructure />

  <ProcessSteps
    eyebrow="HOW IT WORKS"
    title="From First Call to Production"
    steps={[
      { number: "01", title: "Discovery Call", description: "We assess your infrastructure, data landscape, and compliance requirements in a free consultation." },
      { number: "02", title: "Proof of Concept", description: "A working prototype deployed in your environment within 2 weeks, not months." },
      { number: "03", title: "Production Deployment", description: "Full rollout with monitoring, training, and ongoing support. Your AI, your infrastructure." }
    ]}
  />

  <!-- Why Ironum -->
  <section class="px-4 md:px-20 py-20 md:py-32 bg-black text-white">
    <div class="max-w-7xl mx-auto space-y-8">
      <div class="text-center space-y-4">
        <span class="text-orange-500 font-semibold tracking-[0.2em] text-sm uppercase block">WHY IRONUM</span>
        <h2 class="text-3xl md:text-5xl font-bold">Why European Companies Choose Ironum</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 pt-8">
        <div class="border border-white/10 rounded-2xl p-6">
          <h3 class="text-xl font-bold mb-3">Your Data Never Leaves</h3>
          <p class="text-white/60 text-sm">Every byte stays on your servers. No third-party access, no cloud dependencies, no transatlantic data transfers.</p>
        </div>
        <div class="border border-white/10 rounded-2xl p-6">
          <h3 class="text-xl font-bold mb-3">Built for Your Business</h3>
          <p class="text-white/60 text-sm">Not a template. Not a generic platform. Every solution is engineered for your specific workflows, data, and industry.</p>
        </div>
        <div class="border border-white/10 rounded-2xl p-6">
          <h3 class="text-xl font-bold mb-3">Compliant by Default</h3>
          <p class="text-white/60 text-sm">GDPR, EU AI Act, audit trails: built into every deployment from day one. Not bolted on as an afterthought.</p>
        </div>
        <div class="border border-white/10 rounded-2xl p-6">
          <h3 class="text-xl font-bold mb-3">No Lock-In. Ever.</h3>
          <p class="text-white/60 text-sm">Open-source foundations mean you own your models, your data, and your infrastructure. Walk away anytime, but you won't want to.</p>
        </div>
      </div>
      <div class="text-center pt-4">
        <a href="/platform/" class="inline-block bg-blue-600 text-white rounded-full px-6 py-4 font-medium text-lg hover:bg-blue-700 transition-all duration-200 min-h-[48px] touch-manipulation">See How It Works</a>
      </div>
    </div>
  </section>

  <FinalCTA />
  <Footer />
</Layout>
