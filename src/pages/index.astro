---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Hero from '../components/Hero.astro';
import TrustBar from '../components/sections/TrustBar.astro';
import ServiceCard from '../components/cards/ServiceCard.astro';
import IndustryCard from '../components/cards/IndustryCard.astro';
import Infrastructure from '../components/Infrastructure.astro';
import Impacts from '../components/Impacts.astro';
import ProcessSteps from '../components/sections/ProcessSteps.astro';
import FinalCTA from '../components/FinalCTA.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <Navigation />
  <Hero />
  <TrustBar />

  <!-- Services Overview -->
  <section class="px-4 md:px-20 py-20 md:py-32 max-w-7xl mx-auto space-y-8">
    <span class="text-orange-500 font-semibold tracking-[0.2em] text-sm uppercase block">WHAT WE DO</span>
    <h2 class="text-3xl md:text-5xl xl:text-7xl font-bold">Full-Service AI Partner</h2>
    <p class="text-gray-500 text-lg font-semibold max-w-2xl">From strategy to production — we design, build, and deploy AI solutions tailored to your business, your data, and your compliance requirements.</p>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 pt-4">
      <ServiceCard title="AI Consulting & Audits" description="Technical audits, gap analysis, and AI readiness assessments for European enterprises." href="/services/ai-consulting/" />
      <ServiceCard title="Workflow Automation" description="Open-source n8n-based automation — no vendor lock-in, full GDPR compliance." href="/services/workflow-automation/" />
      <ServiceCard title="Enterprise RAG" description="Private knowledge systems powered by your documents. Zero public cloud exposure." href="/services/enterprise-rag/" />
      <ServiceCard title="Chatbot Interfaces" description="Whitelabel AI assistants for customer support, HR, and internal knowledge." href="/services/chatbot-interfaces/" />
      <ServiceCard title="LLM Fine-Tuning" description="Domain-specific AI models trained on your data, deployed on your infrastructure." href="/services/llm-fine-tuning/" />
      <ServiceCard title="GEO Optimization" description="Get discovered by AI search engines — the next frontier of digital visibility." href="/services/geo-optimization/" />
    </div>
  </section>

  <!-- Industry Solutions -->
  <section class="px-4 md:px-20 py-20 md:py-32 bg-gray-50">
    <div class="max-w-7xl mx-auto space-y-8">
      <span class="text-orange-500 font-semibold tracking-[0.2em] text-sm uppercase block">INDUSTRIES</span>
      <h2 class="text-3xl md:text-5xl xl:text-7xl font-bold">Built for Your Industry</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 pt-4">
        <IndustryCard title="Legal" description="GDPR-compliant contract review and compliance automation." href="/industries/legal/" stat="61% of lawyers use AI — only 14% have specialized tools" />
        <IndustryCard title="Manufacturing" description="Industry 4.0 AI for production, quality, and maintenance." href="/industries/manufacturing/" stat="34.6% CAGR — EUR 5.5B German government support" />
        <IndustryCard title="Financial Services" description="Data-driven advisory with full data sovereignty." href="/industries/financial-services/" stat="Moving from AI exploration to implementation" />
        <IndustryCard title="Education" description="LearnSlice AI Mentor for training, exams, and onboarding." href="/industries/education/" stat="EUR 2.11B market — Germany leads with 30.1% share" />
        <IndustryCard title="Healthcare" description="Administrative AI that keeps patient data on your servers." href="/industries/healthcare/" stat="Fastest-growing AI vertical in Europe" />
        <IndustryCard title="Public Sector" description="Sovereign AI for citizen services and document processing." href="/industries/public-sector/" stat="245 AI initiatives across 21 European countries" />
      </div>
    </div>
  </section>

  <Infrastructure />
  <Impacts />

  <ProcessSteps
    eyebrow="HOW IT WORKS"
    title="From First Call to Production"
    steps={[
      { number: "01", title: "Discovery Call", description: "We assess your infrastructure, data landscape, and compliance requirements in a free consultation." },
      { number: "02", title: "Proof of Concept", description: "A working prototype deployed in your environment within 2 weeks — not months." },
      { number: "03", title: "Production Deployment", description: "Full rollout with monitoring, training, and ongoing support. Your AI, your infrastructure." }
    ]}
  />

  <!-- EU AI Act Compliance Banner -->
  <section class="px-4 md:px-20 py-20 md:py-32 bg-black text-white">
    <div class="max-w-7xl mx-auto text-center space-y-6">
      <span class="text-orange-500 font-semibold tracking-[0.2em] text-sm uppercase block">EU AI ACT READY</span>
      <h2 class="text-3xl md:text-5xl font-bold">Compliance Is Not Optional. It's Our Foundation.</h2>
      <p class="text-white/70 text-lg md:text-xl max-w-3xl mx-auto">The EU AI Act enters full enforcement in August 2026. Penalties reach up to EUR 35 million or 7% of global annual turnover. Every Ironum solution is built to meet these requirements from day one.</p>
      <div class="flex flex-wrap justify-center gap-8 pt-8">
        <div class="text-center">
          <span class="text-blue-400 text-4xl font-bold block">GDPR</span>
          <span class="text-white/50 text-sm mt-1 block">Native Compliance</span>
        </div>
        <div class="text-center">
          <span class="text-blue-400 text-4xl font-bold block">EU AI Act</span>
          <span class="text-white/50 text-sm mt-1 block">Ready for Aug 2026</span>
        </div>
        <div class="text-center">
          <span class="text-blue-400 text-4xl font-bold block">100%</span>
          <span class="text-white/50 text-sm mt-1 block">European Hosting</span>
        </div>
        <div class="text-center">
          <span class="text-blue-400 text-4xl font-bold block">DPA/NDA</span>
          <span class="text-white/50 text-sm mt-1 block">Included</span>
        </div>
      </div>
      <a href="/platform/compliance/" class="inline-block bg-blue-600 text-white rounded-full px-6 py-4 font-medium text-lg hover:bg-blue-700 transition-all duration-200 min-h-[48px] touch-manipulation mt-4">Learn About Our Compliance</a>
    </div>
  </section>

  <FinalCTA />
  <Footer />
</Layout>
