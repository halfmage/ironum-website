---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import PageHero from '../../components/sections/PageHero.astro';
import FAQSection from '../../components/sections/FAQSection.astro';
import FinalCTA from '../../components/FinalCTA.astro';
import Footer from '../../components/Footer.astro';
---

<Layout
  title="Deployment Options: Cloud, Azure GDPR, or On-Premises | Ironum"
  description="Deploy AI your way: cloud APIs for speed, Azure GDPR regions for compliance, or fully on-premises for maximum data sovereignty. Compare Ironum deployment options."
>
  <Navigation />

  <PageHero
    eyebrow="DEPLOYMENT"
    title="Deploy Your Way"
    subtitle="Every organization has different compliance, performance, and security requirements. Choose the deployment model that fits, or combine them."
  />

  <!-- 3-Column Comparison -->
  <section class="px-4 md:px-20 py-20 md:py-32">
    <div class="max-w-7xl mx-auto space-y-8">
      <span class="text-orange-500 font-semibold tracking-[0.2em] text-sm uppercase block">COMPARE OPTIONS</span>
      <h2 class="text-3xl md:text-5xl xl:text-7xl font-bold">Three Paths to Production</h2>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 pt-8">
        <!-- Cloud APIs -->
        <div class="border-2 border-gray-100 rounded-2xl p-6 md:p-8 flex flex-col">
          <span class="text-blue-600 text-sm font-bold uppercase tracking-wider">FASTEST START</span>
          <h3 class="text-2xl font-bold mt-2 mb-4">Cloud APIs</h3>
          <p class="text-gray-500 text-lg font-semibold mb-6">Use commercial LLM APIs (OpenAI, Anthropic, Google) with Ironum orchestration. Fastest time-to-value for non-sensitive workloads.</p>
          <ul class="space-y-3 text-gray-500 font-semibold mb-8 flex-1">
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-green-500 mt-1 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              Live in days, not weeks
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-green-500 mt-1 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              No infrastructure to manage
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-green-500 mt-1 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              Pay-per-token pricing
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-yellow-500 mt-1 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M12 3a9 9 0 100 18 9 9 0 000-18z"/></svg>
              Data leaves your network
            </li>
          </ul>
          <p class="text-sm text-gray-400 font-semibold">Best for: PoCs, non-regulated workloads, rapid experimentation</p>
        </div>

        <!-- Azure GDPR -->
        <div class="border-2 border-blue-600 rounded-2xl p-6 md:p-8 flex flex-col relative">
          <span class="absolute -top-3 left-6 bg-blue-600 text-white text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wider">RECOMMENDED</span>
          <span class="text-blue-600 text-sm font-bold uppercase tracking-wider">GDPR COMPLIANT</span>
          <h3 class="text-2xl font-bold mt-2 mb-4">Azure GDPR Regions</h3>
          <p class="text-gray-500 text-lg font-semibold mb-6">Enterprise-grade AI through Microsoft Azure's EU data centers. Full GDPR compliance with DPA, data residency guarantees, and enterprise SLAs.</p>
          <ul class="space-y-3 text-gray-500 font-semibold mb-8 flex-1">
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-green-500 mt-1 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              Data stays in EU regions
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-green-500 mt-1 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              Microsoft DPA included
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-green-500 mt-1 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              Enterprise SLA (99.9%+)
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-green-500 mt-1 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              No model training on your data
            </li>
          </ul>
          <p class="text-sm text-gray-400 font-semibold">Best for: Regulated industries, enterprise customers, GDPR-sensitive data</p>
        </div>

        <!-- On-Premises -->
        <div class="border-2 border-gray-100 rounded-2xl p-6 md:p-8 flex flex-col">
          <span class="text-blue-600 text-sm font-bold uppercase tracking-wider">MAXIMUM CONTROL</span>
          <h3 class="text-2xl font-bold mt-2 mb-4">On-Premises</h3>
          <p class="text-gray-500 text-lg font-semibold mb-6">Full deployment on your own hardware or in your private data center. Open-source models, complete air-gap capability, zero external dependencies.</p>
          <ul class="space-y-3 text-gray-500 font-semibold mb-8 flex-1">
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-green-500 mt-1 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              Zero data leaves your network
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-green-500 mt-1 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              Air-gapped deployment possible
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-green-500 mt-1 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              Open-source models only
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-yellow-500 mt-1 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M12 3a9 9 0 100 18 9 9 0 000-18z"/></svg>
              Requires GPU hardware
            </li>
          </ul>
          <p class="text-sm text-gray-400 font-semibold">Best for: Defense, government, healthcare, maximum data sovereignty</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Decision Matrix -->
  <section class="px-4 md:px-20 py-20 md:py-32 bg-gray-50">
    <div class="max-w-7xl mx-auto space-y-8">
      <span class="text-orange-500 font-semibold tracking-[0.2em] text-sm uppercase block">DECISION GUIDE</span>
      <h2 class="text-3xl md:text-5xl xl:text-7xl font-bold">When to Choose Which</h2>

      <div class="overflow-x-auto pt-8">
        <table class="w-full text-left border-collapse">
          <thead>
            <tr class="border-b-2 border-gray-200">
              <th class="py-4 pr-4 text-lg font-bold">Requirement</th>
              <th class="py-4 px-4 text-lg font-bold">Cloud APIs</th>
              <th class="py-4 px-4 text-lg font-bold">Azure GDPR</th>
              <th class="py-4 pl-4 text-lg font-bold">On-Premises</th>
            </tr>
          </thead>
          <tbody class="text-gray-500 font-semibold">
            <tr class="border-b border-gray-100">
              <td class="py-4 pr-4">GDPR Compliance</td>
              <td class="py-4 px-4">Partial</td>
              <td class="py-4 px-4 text-green-600">Full</td>
              <td class="py-4 pl-4 text-green-600">Full</td>
            </tr>
            <tr class="border-b border-gray-100">
              <td class="py-4 pr-4">EU AI Act Ready</td>
              <td class="py-4 px-4">Depends on provider</td>
              <td class="py-4 px-4 text-green-600">Yes</td>
              <td class="py-4 pl-4 text-green-600">Yes</td>
            </tr>
            <tr class="border-b border-gray-100">
              <td class="py-4 pr-4">Data Residency</td>
              <td class="py-4 px-4">Global</td>
              <td class="py-4 px-4">EU regions</td>
              <td class="py-4 pl-4">Your premises</td>
            </tr>
            <tr class="border-b border-gray-100">
              <td class="py-4 pr-4">Setup Time</td>
              <td class="py-4 px-4 text-green-600">Days</td>
              <td class="py-4 px-4">1-2 weeks</td>
              <td class="py-4 pl-4">2-4 weeks</td>
            </tr>
            <tr class="border-b border-gray-100">
              <td class="py-4 pr-4">Hardware Required</td>
              <td class="py-4 px-4 text-green-600">None</td>
              <td class="py-4 px-4 text-green-600">None</td>
              <td class="py-4 pl-4">GPU servers</td>
            </tr>
            <tr class="border-b border-gray-100">
              <td class="py-4 pr-4">Air-Gap Capable</td>
              <td class="py-4 px-4">No</td>
              <td class="py-4 px-4">No</td>
              <td class="py-4 pl-4 text-green-600">Yes</td>
            </tr>
            <tr>
              <td class="py-4 pr-4">Model Selection</td>
              <td class="py-4 px-4">Commercial</td>
              <td class="py-4 px-4">Azure catalog</td>
              <td class="py-4 pl-4">Open-source / custom</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Technical Requirements -->
  <section class="px-4 md:px-20 py-20 md:py-32">
    <div class="max-w-7xl mx-auto space-y-8">
      <span class="text-orange-500 font-semibold tracking-[0.2em] text-sm uppercase block">TECHNICAL SPECS</span>
      <h2 class="text-3xl md:text-5xl xl:text-7xl font-bold">Technical Requirements</h2>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 pt-8">
        <div class="border-2 border-gray-100 rounded-2xl p-6 md:p-8">
          <h3 class="text-2xl font-bold mb-4">Cloud APIs</h3>
          <ul class="space-y-2 text-gray-500 text-lg font-semibold">
            <li>API keys for chosen providers</li>
            <li>Stable internet connection</li>
            <li>n8n instance (we deploy for you)</li>
            <li>No GPU or special hardware</li>
          </ul>
        </div>
        <div class="border-2 border-gray-100 rounded-2xl p-6 md:p-8">
          <h3 class="text-2xl font-bold mb-4">Azure GDPR</h3>
          <ul class="space-y-2 text-gray-500 text-lg font-semibold">
            <li>Azure subscription (EU region)</li>
            <li>Azure OpenAI access approved</li>
            <li>Network connectivity to Azure</li>
            <li>Optional: Azure AD for SSO</li>
          </ul>
        </div>
        <div class="border-2 border-gray-100 rounded-2xl p-6 md:p-8">
          <h3 class="text-2xl font-bold mb-4">On-Premises</h3>
          <ul class="space-y-2 text-gray-500 text-lg font-semibold">
            <li>NVIDIA GPU (A100/H100 recommended)</li>
            <li>64GB+ RAM, 1TB+ storage</li>
            <li>Docker / Kubernetes environment</li>
            <li>Linux server (Ubuntu 22.04+)</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <FAQSection items={[
    { question: "Can I combine deployment models?", answer: "Yes. Many clients use Azure GDPR for sensitive workloads and cloud APIs for non-sensitive tasks. Our orchestration layer routes queries to the right backend automatically based on data classification rules you define." },
    { question: "How long does deployment take?", answer: "Cloud API setups can be live in 2-3 days. Azure GDPR deployments typically take 1-2 weeks including DPA setup. On-premises deployments take 2-4 weeks depending on hardware readiness and network configuration." },
    { question: "Do I need my own IT team?", answer: "No. Ironum handles deployment, configuration, monitoring, and ongoing maintenance. We provide training for your team to manage day-to-day operations, but we remain available for support and updates." },
    { question: "Can I migrate between deployment models later?", answer: "Yes. Our modular architecture means you can start with cloud APIs and migrate to Azure GDPR or on-premises as your requirements evolve. We handle the migration with zero downtime." },
    { question: "What about latency and performance?", answer: "Cloud APIs typically have 200-500ms response times. Azure GDPR is comparable. On-premises deployments can achieve sub-100ms latency for local models, making them ideal for real-time applications." }
  ]} />

  <FinalCTA />
  <Footer />
</Layout>
