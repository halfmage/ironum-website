---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import PageHero from '../../components/sections/PageHero.astro';
import Footer from '../../components/Footer.astro';

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Resources', href: '/resources/' },
];

const sections = [
  {
    title: 'Blog',
    description: 'Expert insights on GDPR-compliant AI, EU AI Act compliance, enterprise RAG, and workflow automation for European businesses.',
    href: '/resources/blog/',
    icon: 'M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253',
  },
  {
    title: 'Guides',
    description: 'In-depth guides and whitepapers on deploying AI infrastructure, achieving compliance, and automating enterprise workflows.',
    href: '/resources/guides/',
    icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z',
  },
];
---

<Layout title="Resources | Ironum AI Core" description="Expert insights, guides, and resources on GDPR-compliant AI, EU AI Act compliance, and enterprise automation for European businesses." breadcrumbs={breadcrumbs}>
  <Navigation />
  <PageHero eyebrow="RESOURCES" title="Insights on AI, Compliance, and Digital Transformation" subtitle="Practical knowledge for European business leaders navigating AI adoption." ctaLink="" />

  <section class="px-4 md:px-20 py-20 md:py-32">
    <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-6">
      {sections.map(section => (
        <a href={section.href} class="group border-2 border-gray-100 rounded-2xl p-8 md:p-12 hover:border-blue-600 transition-colors block">
          <div class="flex items-center gap-4 mb-6">
            <div class="w-12 h-12 bg-blue-50 rounded-xl flex items-center justify-center group-hover:bg-blue-100 transition-colors">
              <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={section.icon} />
              </svg>
            </div>
            <h2 class="text-2xl font-bold group-hover:text-blue-600 transition-colors">{section.title}</h2>
          </div>
          <p class="text-gray-500 text-lg font-semibold">{section.description}</p>
        </a>
      ))}
    </div>
  </section>

  <Footer />
</Layout>
