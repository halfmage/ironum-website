---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import PageHero from '../../components/sections/PageHero.astro';
import FAQSection from '../../components/sections/FAQSection.astro';
import FinalCTA from '../../components/FinalCTA.astro';
import Footer from '../../components/Footer.astro';

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Industries', href: '/industries/' },
  { label: 'Manufacturing', href: '/industries/manufacturing/' },
];

const faqItems = [
  {
    question: 'Can Ironum AI connect to our existing ERP and MES systems?',
    answer: 'Yes. We use n8n workflow automation to integrate with SAP, Siemens, and other common ERP/MES platforms. Our API-first approach means we connect to your existing data sources without replacing your production systems.',
  },
  {
    question: 'How does on-premise deployment work for factory environments?',
    answer: 'We deploy directly on your factory IT infrastructure or a dedicated edge server. This ensures production data stays within your network, meets German data protection requirements, and operates with minimal latency for real-time applications like quality inspection.',
  },
  {
    question: 'What data do we need to get started with predictive maintenance?',
    answer: 'At minimum, historical sensor data from your machines (vibration, temperature, pressure) and maintenance logs. We typically start with a pilot on 3-5 critical machines, demonstrate ROI within 8-12 weeks, then expand across your production floor.',
  },
  {
    question: 'Is the AI suitable for Mittelstand manufacturers?',
    answer: 'Absolutely. Our solutions are designed specifically for the European Mittelstand. You do not need an in-house AI team — 24% of manufacturers cite AI specialist shortage as a barrier. We handle the entire deployment, training, and ongoing optimization.',
  },
  {
    question: 'How does this relate to the German government technology initiative?',
    answer: 'The EUR 5.5 billion German government "new technologies" initiative supports Industry 4.0 adoption. Our solutions align with funding program requirements and we can support your application for relevant technology grants and subsidies.',
  },
];

const structuredData = [
  {
    "@type": "Service",
    "@id": "https://www.ironum.com/industries/manufacturing/#service",
    "name": "Manufacturing AI Solutions - Industry 4.0",
    "description": "AI-powered predictive maintenance, quality inspection, and workflow automation for European manufacturers. Deployed on German infrastructure.",
    "url": "https://www.ironum.com/industries/manufacturing/",
    "provider": { "@id": "https://www.ironum.com/#organization" },
    "areaServed": { "@type": "Place", "name": "Europe" },
    "serviceType": "AI Infrastructure for Manufacturing"
  },
  {
    "@type": "FAQPage",
    "mainEntity": faqItems.map(item => ({
      "@type": "Question",
      "name": item.question,
      "acceptedAnswer": { "@type": "Answer", "text": item.answer }
    }))
  }
];
---

<Layout
  title="Manufacturing AI Solutions - Industry 4.0 on German Infrastructure | Ironum"
  description="AI-powered predictive maintenance, quality inspection, and production workflow automation. Deployed on-premise or Hetzner cloud in Germany. Built for European manufacturers."
  breadcrumbs={breadcrumbs}
  structuredData={structuredData}
>
  <Navigation />
  <PageHero
    eyebrow="AI FOR MANUFACTURING"
    title="Industry 4.0 AI, Hosted in Germany"
    subtitle="AI manufacturing is growing at 34.6% CAGR. GenAI could boost profitability by 10.7%. Deploy production-ready AI on your factory floor — without hiring an AI team."
  />

  <!-- Challenges Section -->
  <section class="px-4 md:px-20 py-20 md:py-32">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <span class="text-orange-500 font-semibold tracking-[0.2em] text-sm uppercase">The challenge</span>
        <h2 class="text-3xl md:text-5xl font-bold mt-4">Why Manufacturers Struggle With AI</h2>
        <p class="text-gray-500 text-lg font-semibold mt-4 max-w-2xl mx-auto">A 247-firm survey revealed three critical barriers holding back AI adoption in manufacturing.</p>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="border-2 border-gray-100 rounded-2xl p-8">
          <div class="w-12 h-12 bg-red-100 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2 1 3 3 3h10c2 0 3-1 3-3V7c0-2-1-3-3-3H7c-2 0-3 1-3 3z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 12h16" /></svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Data Silos Across Production</h3>
          <p class="text-gray-500">25% of manufacturers cite lack of data as their primary AI barrier. Production data trapped in disconnected ERP, MES, and SCADA systems makes AI deployment nearly impossible without integration expertise.</p>
        </div>
        <div class="border-2 border-gray-100 rounded-2xl p-8">
          <div class="w-12 h-12 bg-red-100 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
          </div>
          <h3 class="text-xl font-bold mb-3">AI Specialist Shortage</h3>
          <p class="text-gray-500">24% of manufacturers cannot find AI talent. The gap between factory floor expertise and AI engineering means most Mittelstand companies are locked out of Industry 4.0 benefits.</p>
        </div>
        <div class="border-2 border-gray-100 rounded-2xl p-8">
          <div class="w-12 h-12 bg-red-100 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Insufficient IT Infrastructure</h3>
          <p class="text-gray-500">24% report inadequate IT systems. Legacy infrastructure cannot support modern AI workloads, yet a complete overhaul is too expensive and disruptive for ongoing production.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Solutions Section -->
  <section class="px-4 md:px-20 py-20 md:py-32 bg-gray-50">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <span class="text-orange-500 font-semibold tracking-[0.2em] text-sm uppercase">Solutions</span>
        <h2 class="text-3xl md:text-5xl font-bold mt-4">AI for Your Production Floor</h2>
        <p class="text-gray-500 text-lg font-semibold mt-4 max-w-2xl mx-auto">Practical AI solutions that integrate with your existing systems — no rip-and-replace required.</p>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="bg-white border-2 border-gray-100 rounded-2xl p-8">
          <div class="w-12 h-12 bg-blue-100 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
          </div>
          <h3 class="text-xl font-bold mb-3">n8n Workflow Automation</h3>
          <p class="text-gray-500 mb-4">Connect your ERP, MES, and production systems with intelligent AI workflows. Automate reporting, order processing, and cross-department data flows without custom code.</p>
          <ul class="space-y-2 text-gray-500 text-sm">
            <li class="flex items-start gap-2"><svg class="w-4 h-4 text-blue-600 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>SAP, Siemens, and custom system integration</li>
            <li class="flex items-start gap-2"><svg class="w-4 h-4 text-blue-600 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>Automated production reporting and alerts</li>
            <li class="flex items-start gap-2"><svg class="w-4 h-4 text-blue-600 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>Self-hosted — production data stays internal</li>
          </ul>
        </div>
        <div class="bg-white border-2 border-gray-100 rounded-2xl p-8">
          <div class="w-12 h-12 bg-blue-100 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>
          </div>
          <h3 class="text-xl font-bold mb-3">AI Quality Inspection</h3>
          <p class="text-gray-500 mb-4">AI-powered visual inspection and defect detection integrated into your production line. Reduce scrap rates, catch defects earlier, and maintain consistent quality standards.</p>
          <ul class="space-y-2 text-gray-500 text-sm">
            <li class="flex items-start gap-2"><svg class="w-4 h-4 text-blue-600 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>Real-time defect detection on production line</li>
            <li class="flex items-start gap-2"><svg class="w-4 h-4 text-blue-600 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>Custom-trained on your product specifications</li>
            <li class="flex items-start gap-2"><svg class="w-4 h-4 text-blue-600 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>Edge deployment for minimal latency</li>
          </ul>
        </div>
        <div class="bg-white border-2 border-gray-100 rounded-2xl p-8">
          <div class="w-12 h-12 bg-blue-100 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Predictive Maintenance Analytics</h3>
          <p class="text-gray-500 mb-4">Machine learning models trained on your sensor data to predict failures before they happen. Reduce unplanned downtime, optimize maintenance schedules, and extend equipment life.</p>
          <ul class="space-y-2 text-gray-500 text-sm">
            <li class="flex items-start gap-2"><svg class="w-4 h-4 text-blue-600 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>Anomaly detection from vibration and sensor data</li>
            <li class="flex items-start gap-2"><svg class="w-4 h-4 text-blue-600 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>Maintenance scheduling optimization</li>
            <li class="flex items-start gap-2"><svg class="w-4 h-4 text-blue-600 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>ROI typically visible within 8-12 weeks</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats Section -->
  <section class="px-4 md:px-20 py-20 md:py-32">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <span class="text-orange-500 font-semibold tracking-[0.2em] text-sm uppercase">Market opportunity</span>
        <h2 class="text-3xl md:text-5xl font-bold mt-4">The Numbers Behind Industry 4.0</h2>
      </div>
      <div class="grid md:grid-cols-4 gap-8 text-center">
        <div class="border-2 border-gray-100 rounded-2xl p-8">
          <div class="text-blue-600 text-5xl font-bold mb-2">34.6%</div>
          <p class="text-gray-500 text-lg font-semibold">CAGR in AI manufacturing globally</p>
        </div>
        <div class="border-2 border-gray-100 rounded-2xl p-8">
          <div class="text-blue-600 text-5xl font-bold mb-2">10.7%</div>
          <p class="text-gray-500 text-lg font-semibold">Potential profitability boost from GenAI adoption</p>
        </div>
        <div class="border-2 border-gray-100 rounded-2xl p-8">
          <div class="text-blue-600 text-4xl font-bold mb-2">&euro;5.5B</div>
          <p class="text-gray-500 text-lg font-semibold">German government "new technologies" initiative</p>
        </div>
        <div class="border-2 border-gray-100 rounded-2xl p-8">
          <div class="text-blue-600 text-5xl font-bold mb-2">100%</div>
          <p class="text-gray-500 text-lg font-semibold">Production data stays on your infrastructure</p>
        </div>
      </div>
    </div>
  </section>

  <FAQSection items={faqItems} />
  <FinalCTA />
  <Footer />
</Layout>
