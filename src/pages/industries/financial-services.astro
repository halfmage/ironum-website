---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import PageHero from '../../components/sections/PageHero.astro';
import FAQSection from '../../components/sections/FAQSection.astro';
import FinalCTA from '../../components/FinalCTA.astro';
import Footer from '../../components/Footer.astro';

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Industries', href: '/industries/' },
  { label: 'Financial Services', href: '/industries/financial-services/' },
];

const faqItems = [
  {
    question: 'How does Ironum ensure compliance with BaFin and ECB regulations?',
    answer: 'Our deployments are designed for regulated financial environments. All data processing happens on your infrastructure — on-premise or in a dedicated Azure tenant — ensuring compliance with BaFin IT requirements (BAIT/VAIT), ECB supervisory expectations, and GDPR. We include full audit trails, model documentation, and explainability features required by financial regulators.',
  },
  {
    question: 'Can the AI be deployed in our existing banking infrastructure?',
    answer: 'Yes. We deploy directly into your data center, private cloud, or dedicated Azure environment. Our solutions integrate with core banking systems via secure APIs and n8n workflow automation. No customer data ever leaves your controlled environment.',
  },
  {
    question: 'What fraud detection capabilities do you offer?',
    answer: 'Our AI models analyze transaction patterns in real-time to detect anomalies indicative of fraud. Models are trained on your historical data and continuously learn from new patterns. All processing happens on-premise, ensuring customer transaction data remains fully sovereign.',
  },
  {
    question: 'How does this compare to using ChatGPT or public AI services for financial analysis?',
    answer: 'Public AI services are unsuitable for financial data due to data sovereignty concerns, regulatory non-compliance, and the risk of data leakage. Our on-premise deployments provide the same AI capabilities — document analysis, risk modeling, compliance automation — without sending any customer data to third-party servers. 44% of enterprises cite data security as the primary reason for avoiding public cloud AI.',
  },
  {
    question: 'What is the typical deployment timeline for a financial institution?',
    answer: 'A pilot deployment typically takes 6-10 weeks, including security assessment, infrastructure setup, model training, and compliance documentation. Full production rollout follows in phases, aligned with your change management and regulatory approval processes.',
  },
];

const structuredData = [
  {
    "@type": "Service",
    "@id": "https://www.ironum.com/industries/financial-services/#service",
    "name": "Financial Services AI Solutions",
    "description": "Data-sovereign AI for fraud detection, KYC/AML automation, risk modeling, and regulatory compliance. On-premise deployment for banking data.",
    "url": "https://www.ironum.com/industries/financial-services/",
    "provider": { "@id": "https://www.ironum.com/#organization" },
    "areaServed": { "@type": "Place", "name": "Europe" },
    "serviceType": "AI Infrastructure for Financial Services"
  },
  {
    "@type": "FAQPage",
    "mainEntity": faqItems.map(item => ({
      "@type": "Question",
      "name": item.question,
      "acceptedAnswer": { "@type": "Answer", "text": item.answer }
    }))
  }
];
---

<Layout
  title="Financial Services AI - Data-Sovereign Fraud Detection & Compliance | Ironum"
  description="AI-powered fraud detection, KYC/AML automation, risk modeling, and compliance for European financial institutions. Full data sovereignty on your infrastructure."
  breadcrumbs={breadcrumbs}
  structuredData={structuredData}
>
  <Navigation />
  <PageHero
    eyebrow="AI FOR FINANCE"
    title="Data-Driven Advisory With Full Data Sovereignty"
    subtitle="European banks are moving from AI exploration to operational implementation in 2026. Deploy on-premise AI for fraud detection, compliance automation, and risk modeling — without compromising customer data."
  />

  <!-- Challenges Section -->
  <section class="px-4 md:px-20 py-20 md:py-32">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <span class="text-orange-500 font-semibold tracking-[0.2em] text-sm uppercase">The challenge</span>
        <h2 class="text-3xl md:text-5xl font-bold mt-4">Banking Data Cannot Live in the Cloud</h2>
        <p class="text-gray-500 text-lg font-semibold mt-4 max-w-2xl mx-auto">Financial institutions face unique constraints when adopting AI — regulatory pressure, data sensitivity, and the need for explainable decisions.</p>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="border-2 border-gray-100 rounded-2xl p-8">
          <div class="w-12 h-12 bg-red-100 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" /></svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Regulatory Complexity</h3>
          <p class="text-gray-500">BaFin IT requirements (BAIT/VAIT), ECB supervisory expectations, GDPR, EU AI Act, and MiFID II create overlapping compliance obligations that generic AI tools cannot address.</p>
        </div>
        <div class="border-2 border-gray-100 rounded-2xl p-8">
          <div class="w-12 h-12 bg-red-100 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Customer Data Sovereignty</h3>
          <p class="text-gray-500">Transaction data, account information, and customer profiles cannot be processed by third-party AI services. 72% of EU security professionals report heightened demand for data localization in financial services.</p>
        </div>
        <div class="border-2 border-gray-100 rounded-2xl p-8">
          <div class="w-12 h-12 bg-red-100 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Explainability Requirements</h3>
          <p class="text-gray-500">Regulators require that AI-driven decisions in credit scoring, risk assessment, and compliance can be explained and audited. Black-box AI models are not acceptable in regulated finance.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Solutions Section -->
  <section class="px-4 md:px-20 py-20 md:py-32 bg-gray-50">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <span class="text-orange-500 font-semibold tracking-[0.2em] text-sm uppercase">Solutions</span>
        <h2 class="text-3xl md:text-5xl font-bold mt-4">Your AI Factory, Your Infrastructure</h2>
        <p class="text-gray-500 text-lg font-semibold mt-4 max-w-2xl mx-auto">Leading European banks are building "AI factories" for regional deployment. We provide the infrastructure and expertise to build yours.</p>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="bg-white border-2 border-gray-100 rounded-2xl p-8">
          <div class="w-12 h-12 bg-blue-100 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>
          </div>
          <h3 class="text-xl font-bold mb-3">DIN Analysis Companion</h3>
          <p class="text-gray-500 mb-4">AI-powered analysis of DIN financial standards, regulatory publications, and compliance documentation. Instantly search, compare, and extract requirements from thousands of regulatory documents.</p>
          <ul class="space-y-2 text-gray-500 text-sm">
            <li class="flex items-start gap-2"><svg class="w-4 h-4 text-blue-600 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>RAG-powered regulatory document search</li>
            <li class="flex items-start gap-2"><svg class="w-4 h-4 text-blue-600 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>Cross-reference across DIN, BaFin, and ECB</li>
            <li class="flex items-start gap-2"><svg class="w-4 h-4 text-blue-600 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>Source-cited answers with document links</li>
          </ul>
        </div>
        <div class="bg-white border-2 border-gray-100 rounded-2xl p-8">
          <div class="w-12 h-12 bg-blue-100 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Regulatory Compliance Automation</h3>
          <p class="text-gray-500 mb-4">Automate KYC/AML screening, transaction monitoring, and regulatory reporting. Reduce manual compliance workload while maintaining full audit trails for supervisory reviews.</p>
          <ul class="space-y-2 text-gray-500 text-sm">
            <li class="flex items-start gap-2"><svg class="w-4 h-4 text-blue-600 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>Automated KYC/AML document verification</li>
            <li class="flex items-start gap-2"><svg class="w-4 h-4 text-blue-600 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>Real-time transaction anomaly detection</li>
            <li class="flex items-start gap-2"><svg class="w-4 h-4 text-blue-600 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>Regulatory report generation with n8n</li>
          </ul>
        </div>
        <div class="bg-white border-2 border-gray-100 rounded-2xl p-8">
          <div class="w-12 h-12 bg-blue-100 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Financial Planning AI</h3>
          <p class="text-gray-500 mb-4">AI-assisted risk modeling, portfolio analysis, and financial planning. Support advisors with data-driven insights while keeping all customer financial data on your own servers.</p>
          <ul class="space-y-2 text-gray-500 text-sm">
            <li class="flex items-start gap-2"><svg class="w-4 h-4 text-blue-600 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>Risk scoring with explainable AI models</li>
            <li class="flex items-start gap-2"><svg class="w-4 h-4 text-blue-600 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>Market data analysis and summarization</li>
            <li class="flex items-start gap-2"><svg class="w-4 h-4 text-blue-600 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>On-prem or dedicated Azure deployment</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats Section -->
  <section class="px-4 md:px-20 py-20 md:py-32">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <span class="text-orange-500 font-semibold tracking-[0.2em] text-sm uppercase">Market data</span>
        <h2 class="text-3xl md:text-5xl font-bold mt-4">The AI Shift in European Finance</h2>
      </div>
      <div class="grid md:grid-cols-4 gap-8 text-center">
        <div class="border-2 border-gray-100 rounded-2xl p-8">
          <div class="text-blue-600 text-4xl font-bold mb-2">&euro;37B</div>
          <p class="text-gray-500 text-lg font-semibold">Projected AI market in Germany by 2031</p>
        </div>
        <div class="border-2 border-gray-100 rounded-2xl p-8">
          <div class="text-blue-600 text-5xl font-bold mb-2">72%</div>
          <p class="text-gray-500 text-lg font-semibold">Of EU security professionals demand data localization</p>
        </div>
        <div class="border-2 border-gray-100 rounded-2xl p-8">
          <div class="text-blue-600 text-5xl font-bold mb-2">44%</div>
          <p class="text-gray-500 text-lg font-semibold">Cite data security as barrier to cloud AI</p>
        </div>
        <div class="border-2 border-gray-100 rounded-2xl p-8">
          <div class="text-blue-600 text-5xl font-bold mb-2">100%</div>
          <p class="text-gray-500 text-lg font-semibold">Customer data stays on your infrastructure</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Related Services -->
  <section class="px-4 md:px-20 py-20 md:py-32 bg-gray-50">
    <div class="max-w-7xl mx-auto space-y-8">
      <span class="text-orange-500 font-semibold tracking-[0.2em] text-sm uppercase block">RELATED SERVICES</span>
      <h2 class="text-3xl md:text-5xl font-bold">Solutions That Power Financial Services AI</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <a href="/services/enterprise-rag/" class="border-2 border-gray-100 rounded-2xl p-8 bg-white hover:border-blue-200 transition-colors group">
          <h3 class="text-xl font-bold mb-3">Enterprise RAG</h3>
          <p class="text-gray-500 font-semibold mb-4">AI-powered search across regulatory documents, DIN standards, and compliance archives with source citations.</p>
          <span class="text-blue-600 font-semibold inline-flex items-center gap-1 group-hover:gap-2 transition-all">Learn more <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg></span>
        </a>
        <a href="/services/workflow-automation/" class="border-2 border-gray-100 rounded-2xl p-8 bg-white hover:border-blue-200 transition-colors group">
          <h3 class="text-xl font-bold mb-3">Workflow Automation</h3>
          <p class="text-gray-500 font-semibold mb-4">Automate KYC/AML screening, transaction monitoring, and regulatory reporting with self-hosted n8n workflows.</p>
          <span class="text-blue-600 font-semibold inline-flex items-center gap-1 group-hover:gap-2 transition-all">Learn more <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg></span>
        </a>
        <a href="/services/llm-fine-tuning/" class="border-2 border-gray-100 rounded-2xl p-8 bg-white hover:border-blue-200 transition-colors group">
          <h3 class="text-xl font-bold mb-3">LLM Fine-Tuning</h3>
          <p class="text-gray-500 font-semibold mb-4">Train domain-specific models on financial terminology, risk frameworks, and regulatory language.</p>
          <span class="text-blue-600 font-semibold inline-flex items-center gap-1 group-hover:gap-2 transition-all">Learn more <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg></span>
        </a>
      </div>
    </div>
  </section>

  <FAQSection items={faqItems} />
  <FinalCTA />
  <Footer />
</Layout>
