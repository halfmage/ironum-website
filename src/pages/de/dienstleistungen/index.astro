---
import Layout from '../../../layouts/Layout.astro';
import Navigation from '../../../components/Navigation.astro';
import PageHero from '../../../components/sections/PageHero.astro';
import FinalCTA from '../../../components/FinalCTA.astro';
import Footer from '../../../components/Footer.astro';

const services = [
  {
    title: 'Enterprise RAG-Lösungen',
    description: 'Verwandeln Sie verteilte Dokumente in eine durchsuchbare, private Wissensdatenbank. Retrieval-Augmented Generation auf Ihrer eigenen Infrastruktur, DSGVO-konform von Anfang an.',
    href: '/de/dienstleistungen/enterprise-rag',
    icon: 'M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z',
  },
  {
    title: 'Workflow-Automatisierung',
    description: 'Eliminieren Sie manuelle Prozesse mit n8n-basierter Workflow-Automatisierung. Self-hosted, Open Source und integriert mit über 400 Business-Tools, ohne Vendor Lock-in.',
    href: '/de/dienstleistungen/workflow-automatisierung',
    icon: 'M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z',
  },
  {
    title: 'KI-Beratung & Audits',
    description: 'Von der KI-Strategie zur Produktion. Technische Audits, Readiness-Assessments und Integrationsplanung, zugeschnitten auf europäische Compliance-Anforderungen.',
    href: '/de/dienstleistungen/ki-beratung',
    icon: 'M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z',
  },
  {
    title: 'Chatbot & Conversational AI',
    description: 'KI-Assistenten, die Ihr Unternehmen wirklich kennen. White-Label, Multi-Channel Chatbots auf Basis Ihrer eigenen Daten mit höchsten Datenschutzstandards.',
    href: '/de/dienstleistungen/chatbot-schnittstellen',
    icon: 'M8.625 12a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H8.25m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H12m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 01-2.555-.337A5.972 5.972 0 015.41 20.97a5.969 5.969 0 01-.474-.065 4.48 4.48 0 00.978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25z',
  },
  {
    title: 'LLM-Feinabstimmung',
    description: 'Trainieren Sie domainspezifische KI-Modelle mit Ihren eigenen Daten. Open-Source-LLMs, feinabgestimmt auf Ihre Branche. Ihre Daten verlassen nie Ihre Infrastruktur.',
    href: '/de/dienstleistungen/llm-feinabstimmung',
    icon: 'M4.26 10.147a60.438 60.438 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342',
  },
  {
    title: 'Generative Engine Optimization',
    description: 'Werden Sie von KI gefunden, nicht nur von Suchmaschinen. Optimieren Sie Ihre Markensichtbarkeit in ChatGPT, Perplexity und anderen KI-Antwortmaschinen.',
    href: '/de/dienstleistungen/geo-optimierung',
    icon: 'M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418',
  },
];

const deploymentOptions = [
  {
    title: 'Cloud-APIs',
    description: 'Anbindung an OpenAI, Anthropic oder Google APIs für schnelle Bereitstellung und Zugang zu Frontier-Modellen. Ideal für Teams, die mit KI starten.',
    features: ['OpenAI, Anthropic, Google', 'Schnellste Time-to-Value', 'Pay-per-Use-Preismodell'],
  },
  {
    title: 'Microsoft Azure (DSGVO)',
    description: 'Deployment auf Azure mit EU-Datenresidenz-Garantie. Ihre Daten bleiben in europäischen Rechenzentren mit voller DSGVO-Konformität und Enterprise-SLAs.',
    features: ['EU-Datenresidenz', 'Enterprise-SLAs', 'DSGVO-konform by Design'],
  },
  {
    title: 'On-Premises / Hetzner',
    description: 'Volle Datensouveränität mit On-Premises-Deployment oder deutscher Hosting-Infrastruktur auf Hetzner. Kein Byte verlässt Ihre Kontrolle.',
    features: ['100 % Datensouveränität', 'Deutsches Hosting verfügbar', 'Open-Source-LLMs'],
  },
];

const structuredData = [
  {
    "@type": "Service",
    "@id": "https://www.ironum.com/de/dienstleistungen/#service",
    "name": "Ironum KI-Dienstleistungen",
    "description": "Ihr KI-Partner für den europäischen Mittelstand. Enterprise RAG, Workflow-Automatisierung, KI-Beratung, Chatbots, LLM-Feinabstimmung und GEO.",
    "provider": { "@id": "https://www.ironum.com/#organization" },
    "areaServed": { "@type": "Place", "name": "Europe" },
    "serviceType": "KI-Lösungen",
    "inLanguage": "de"
  }
];

const breadcrumbs = [
  { label: 'Startseite', href: '/de' },
  { label: 'Dienstleistungen', href: '/de/dienstleistungen' },
];
---

<Layout
  locale="de"
  title="KI-Dienstleistungen für den Mittelstand | Ironum"
  description="Ihr KI-Partner: Enterprise RAG, Workflow-Automatisierung, KI-Beratung, Chatbots, LLM-Feinabstimmung und Generative Engine Optimization. DSGVO-konform, europäisches Hosting."
  breadcrumbs={breadcrumbs}
  structuredData={structuredData}
>
  <Navigation />

  <PageHero
    eyebrow="UNSERE DIENSTLEISTUNGEN"
    title="KI-Lösungen für den europäischen Mittelstand"
    subtitle="Ihr Full-Service-KI-Partner, von der Strategie bis zur Produktion. Jede Lösung DSGVO-konform, jedes Deployment auf Infrastruktur, die Sie kontrollieren."
  />

  <!-- Services Grid -->
  <section class="px-4 md:px-20 py-20 md:py-32">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <span class="text-orange-500 font-semibold tracking-[0.2em] text-sm uppercase">Was wir bauen</span>
        <h2 class="text-3xl md:text-5xl font-bold mt-4">Sechs Säulen der Unternehmens-KI</h2>
        <p class="text-gray-500 text-lg font-semibold mt-4 max-w-2xl mx-auto">Jede Dienstleistung funktioniert eigenständig oder als Teil eines integrierten KI-Stacks. Alle Lösungen laufen auf Ihrer Infrastruktur mit voller Datensouveränität.</p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {services.map((service) => (
          <a href={service.href} class="border-2 border-gray-100 rounded-2xl p-8 hover:border-blue-200 hover:shadow-lg transition-all duration-200 group block">
            <div class="w-12 h-12 bg-blue-50 rounded-xl flex items-center justify-center mb-6 group-hover:bg-blue-100 transition-colors">
              <svg class="w-6 h-6 text-blue-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d={service.icon} />
              </svg>
            </div>
            <h3 class="text-xl font-bold mb-3">{service.title}</h3>
            <p class="text-gray-500 text-lg font-semibold">{service.description}</p>
            <span class="inline-flex items-center text-blue-600 font-semibold mt-4 group-hover:gap-2 transition-all">
              Mehr erfahren
              <svg class="w-4 h-4 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Deployment Options -->
  <section class="px-4 md:px-20 py-20 md:py-32 bg-gray-50">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <span class="text-orange-500 font-semibold tracking-[0.2em] text-sm uppercase">Deployment</span>
        <h2 class="text-3xl md:text-5xl font-bold mt-4">Ihre Infrastruktur, Ihre Regeln</h2>
        <p class="text-gray-500 text-lg font-semibold mt-4 max-w-2xl mx-auto">Wählen Sie das Deployment-Modell, das zu Ihren Compliance-Anforderungen passt. Jede Option ist produktionsreif und wird vollständig von unserem Team betreut.</p>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        {deploymentOptions.map((option) => (
          <div class="bg-white border-2 border-gray-100 rounded-2xl p-8">
            <h3 class="text-xl font-bold mb-3">{option.title}</h3>
            <p class="text-gray-500 text-lg font-semibold mb-6">{option.description}</p>
            <ul class="space-y-3">
              {option.features.map((feature) => (
                <li class="flex items-center gap-3">
                  <svg class="w-5 h-5 text-green-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                  <span class="text-gray-700 font-medium">{feature}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Enterprise-Grade by Default -->
  <section class="px-4 md:px-20 py-20 md:py-32">
    <div class="max-w-7xl mx-auto">
      <div class="bg-black rounded-2xl p-8 md:p-16 text-center">
        <span class="text-orange-500 font-semibold tracking-[0.2em] text-sm uppercase">Richtig gebaut</span>
        <h2 class="text-white text-3xl md:text-5xl font-bold mt-4">Enterprise-Qualität als Standard</h2>
        <p class="text-white/80 text-lg md:text-xl font-medium mt-4 max-w-3xl mx-auto">Jede Lösung umfasst DSGVO-Konformität, Datensouveränität, Audit-Logging und AVV/NDA, weil das Standard sein sollte, kein optionales Add-on.</p>
        <div class="grid md:grid-cols-3 gap-8 mt-12 text-left">
          <div>
            <h3 class="text-white text-lg font-bold mb-2">Datensouveränität</h3>
            <p class="text-white/60 font-medium">Alle Datenverarbeitung bleibt innerhalb der EU-Grenzen. Keine transatlantischen Datentransfers, kein Zugriff Dritter.</p>
          </div>
          <div>
            <h3 class="text-white text-lg font-bold mb-2">Sicherheit von Anfang an</h3>
            <p class="text-white/60 font-medium">Verschlüsselung, rollenbasierte Zugriffskontrolle und Audit-Trails in jedem Deployment von Tag eins.</p>
          </div>
          <div>
            <h3 class="text-white text-lg font-bold mb-2">Vollständig dokumentiert</h3>
            <p class="text-white/60 font-medium">Modelldokumentation, Daten-Lineage-Tracking und Transparenzberichte, bereit wenn Sie sie brauchen.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <FinalCTA />
  <Footer />
</Layout>
