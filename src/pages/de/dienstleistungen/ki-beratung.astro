---
import Layout from '../../../layouts/Layout.astro';
import Navigation from '../../../components/Navigation.astro';
import PageHero from '../../../components/sections/PageHero.astro';
import FAQSection from '../../../components/sections/FAQSection.astro';
import FinalCTA from '../../../components/FinalCTA.astro';
import Footer from '../../../components/Footer.astro';

const services = [
  {
    title: 'Technisches KI-Audit',
    description: 'Wir bewerten Ihren aktuellen Technologie-Stack, Ihre Dateninfrastruktur und die Fähigkeiten Ihres Teams. Sie erhalten ein klares Bild davon, was KI mit Ihren vorhandenen Ressourcen realistisch erreichen kann und welche Lücken geschlossen werden müssen.',
    icon: 'M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z',
  },
  {
    title: 'Gap-Analyse',
    description: 'Wir gleichen Ihre Geschäftsprozesse mit KI-Möglichkeiten ab. Identifizieren Sie, wo KI den höchsten ROI liefert, welche Prozesse automatisierungsreif sind und welche Datenvorbereitung nötig ist, bevor eine einzige Zeile Code geschrieben wird.',
    icon: 'M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5m.75-9l3-3 2.148 2.148A12.061 12.061 0 0116.5 7.605',
  },
  {
    title: 'KI-Readiness-Assessment',
    description: 'Nicht jedes Unternehmen ist bereit für KI. Wir bewerten Ihre Datenqualität, Governance-Prozesse, Team-Kompetenzen und Compliance-Situation, um genau festzustellen, wo Sie stehen, und erstellen eine Roadmap, um Sie dorthin zu bringen, wo Sie sein müssen.',
    icon: 'M11.35 3.836c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m8.9-4.414c.376.023.75.05 1.124.08 1.131.094 1.976 1.057 1.976 2.192V16.5A2.25 2.25 0 0118 18.75h-2.25m-7.5-10.5H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V18.75m-7.5-10.5h6.375c.621 0 1.125.504 1.125 1.125v9.375m-8.25-3l1.5 1.5 3-3.75',
  },
  {
    title: 'Integrationsplanung',
    description: 'Detaillierte technische Architektur für die Integration von KI in Ihre bestehenden Systeme. Wir planen Datenpipelines, API-Anbindungen, Sicherheitsschichten und Deployment-Infrastruktur, damit die Umsetzung von Tag eins an reibungslos läuft.',
    icon: 'M6.429 9.75L2.25 12l4.179 2.25m0-4.5l5.571 3 5.571-3m-11.142 0L2.25 7.5 12 2.25l9.75 5.25-4.179 2.25m0 0L21.75 12l-4.179 2.25m0 0l4.179 2.25L12 21.75 2.25 16.5l4.179-2.25m11.142 0l-5.571 3-5.571-3',
  },
];

const processSteps = [
  {
    step: '01',
    title: 'Analyse',
    duration: '1-2 Wochen',
    description: 'Tiefgehende Analyse Ihres Technologie-Stacks, Ihrer Datenlandschaft, Geschäftsprozesse und Compliance-Anforderungen. Wir führen Stakeholder-Interviews, prüfen Dokumentation und auditieren bestehende Systeme.',
    deliverables: ['Technischer Audit-Bericht', 'Datenqualitäts-Assessment', 'Stakeholder-Interview-Zusammenfassungen'],
  },
  {
    step: '02',
    title: 'Strategie',
    duration: '1-2 Wochen',
    description: 'Wir entwickeln eine priorisierte KI-Roadmap basierend auf ROI-Potenzial, technischer Machbarkeit und Compliance-Anforderungen. Jede Empfehlung umfasst Kostenschätzungen, Zeitpläne und Risikobewertungen.',
    deliverables: ['KI-Roadmap mit Prioritäten', 'Business Case pro Initiative', 'Risiko- und Compliance-Bewertung'],
  },
  {
    step: '03',
    title: 'Umsetzung',
    duration: '4-12 Wochen',
    description: 'Praktische Entwicklung und Deployment. Wir bauen Proof-of-Concepts, iterieren mit Ihrem Team und deployen produktionsreife KI-Lösungen auf Ihrer Infrastruktur.',
    deliverables: ['Funktionierender Proof-of-Concept', 'Produktions-Deployment', 'Technische Dokumentation'],
  },
  {
    step: '04',
    title: 'Betreuung',
    duration: 'Laufend',
    description: 'Monitoring nach dem Launch, Performance-Optimierung und Teamschulungen. Wir stellen sicher, dass Ihre KI-Lösungen nachhaltigen Mehrwert liefern und bei neuen Regulierungen konform bleiben.',
    deliverables: ['Performance-Monitoring', 'Team-Schulungen', 'Quartalsweise Review und Optimierung'],
  },
];

const audiences = [
  {
    title: 'CTOs im Mittelstand',
    description: 'Sie wissen, dass KI wichtig ist, aber es fehlt die interne Expertise, um Anbieter zu bewerten, Modelle auszuwählen oder Lösungen zu architekturieren. Sie brauchen einen technischen Partner, der Ihre Sprache spricht und europäische Compliance versteht.',
    challenges: ['KI-Anbieter-Claims bewerten', 'Build-vs-Buy-Entscheidungen', 'KI-Talente in einem engen Markt finden'],
  },
  {
    title: 'Operations-Verantwortliche',
    description: 'Sie sehen tägliche Ineffizienzen, die KI lösen könnte, wissen aber nicht, wo Sie anfangen sollen. Sie brauchen jemanden, der die Automatisierungsmöglichkeiten mit dem höchsten ROI identifiziert und funktionierende Lösungen liefert, keine Slide-Decks.',
    challenges: ['Automatisierungskandidaten identifizieren', 'KI-ROI messen', 'Change Management für KI-Einführung'],
  },
  {
    title: 'Compliance-Beauftragte',
    description: 'Ihr Unternehmen führt KI abteilungsübergreifend ein. Sie brauchen die Gewissheit, dass jedes Deployment Sicherheits-, Datenschutz- und Regulierungsstandards erfüllt, ohne die Innovation zu bremsen.',
    challenges: ['EU-KI-Verordnung Risikoklassifizierung', 'DSGVO-konforme KI-Verarbeitung', 'Audit-Dokumentation und Transparenz'],
  },
];

const faqItems = [
  {
    question: 'Was kostet ein KI-Beratungsprojekt typischerweise?',
    answer: 'Ein erstes Assessment- und Strategieprojekt dauert in der Regel 2 bis 4 Wochen und wird als Festpreis-Projekt angeboten. Umsetzungsprojekte werden nach Komplexität kalkuliert. Nach dem ersten Scoping-Gespräch erhalten Sie ein transparentes, aufgeschlüsseltes Angebot, ohne versteckte Kosten, ohne offene Retainer.',
  },
  {
    question: 'Wir haben intern keine KI-Erfahrung. Können Sie trotzdem helfen?',
    answer: 'Auf jeden Fall. Die meisten unserer Kunden starten ohne KI-Erfahrung. Unser Beratungsprozess ist darauf ausgelegt, Sie dort abzuholen, wo Sie stehen, von der Erklärung grundlegender Konzepte für Ihr Führungsteam über die Identifikation des richtigen ersten Projekts bis hin zum Aufbau und Deployment der Lösung. Wir schulen auch Ihr Team, damit es KI-Lösungen eigenständig verwalten und erweitern kann.',
  },
  {
    question: 'Wie gehen Sie mit der EU-KI-Verordnung um?',
    answer: 'Wir klassifizieren jeden KI-Anwendungsfall gemäß dem Risikorahmen der EU-KI-Verordnung, dokumentieren die erforderlichen Transparenz- und Aufsichtsmaßnahmen und bauen Compliance in jedes Deployment ein. Für Hochrisiko-Anwendungen implementieren wir die erforderlichen Risikomanagementsysteme, Data-Governance-Prozesse und menschliche Aufsichtsmechanismen von Anfang an.',
  },
  {
    question: 'Arbeiten Sie mit bestimmten Branchen?',
    answer: 'Wir arbeiten branchenübergreifend, haben aber tiefe Erfahrung in Professional Services (Recht, Beratung), Fertigung, Finanzdienstleistungen und Gesundheitswesen. Unser Ansatz ist auf Technologieebene branchenunabhängig, aber auf Geschäftsprozessebene hochgradig individualisiert. Wir lernen Ihre Domäne als Teil jedes Projekts.',
  },
  {
    question: 'Was passiert nach der Beratungsphase?',
    answer: 'Alles, was wir bauen, gehört Ihnen. Alle Dokumentationen, Code, Konfigurationen und Modelle sind Ihr Eigentum. Wir können als Umsetzungspartner weitermachen, laufende Managed Services erbringen oder an Ihr internes Team mit vollständiger Schulung und Dokumentation übergeben. Es gibt kein Lock-in.',
  },
];

const structuredData = [
  {
    "@type": "Service",
    "@id": "https://www.ironum.com/de/dienstleistungen/ki-beratung/#service",
    "name": "KI-Beratung & Audits",
    "description": "Von der KI-Strategie zur Produktion. Technische Audits, KI-Readiness-Assessments und Integrationsplanung für den europäischen Mittelstand. EU-KI-Verordnung konform.",
    "provider": { "@id": "https://www.ironum.com/#organization" },
    "areaServed": { "@type": "Place", "name": "Europe" },
    "serviceType": "KI-Beratung",
    "inLanguage": "de"
  }
];

const breadcrumbs = [
  { label: 'Startseite', href: '/de' },
  { label: 'Dienstleistungen', href: '/de/dienstleistungen' },
  { label: 'KI-Beratung', href: '/de/dienstleistungen/ki-beratung' },
];
---

<Layout
  locale="de"
  title="KI-Beratung & Audits für den Mittelstand | Ironum"
  description="Von der KI-Strategie zur Produktion ohne Umwege. Technische Audits, KI-Readiness-Assessments und Integrationsplanung für den europäischen Mittelstand. EU-KI-Verordnung konform."
  breadcrumbs={breadcrumbs}
  structuredData={structuredData}
>
  <Navigation />

  <PageHero
    eyebrow="KI-BERATUNG"
    title="Von der KI-Strategie zur Produktion, ohne Umwege"
    subtitle="Technische Audits, Readiness-Assessments und praxisnahe Umsetzung. Wir helfen europäischen Unternehmen, KI einzusetzen, die funktioniert, konform ist und messbaren ROI liefert."
  />

  <!-- What We Do -->
  <section class="px-4 md:px-20 py-20 md:py-32">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <span class="text-orange-500 font-semibold tracking-[0.2em] text-sm uppercase">Was wir tun</span>
        <h2 class="text-3xl md:text-5xl font-bold mt-4">Praxisnahe KI-Beratung, keine PowerPoints</h2>
        <p class="text-gray-500 text-lg font-semibold mt-4 max-w-2xl mx-auto">Wir sind Ingenieure, keine Unternehmensberater. Jede Empfehlung kommt mit einer technischen Architektur, einem realistischen Zeitplan und einem klaren Business Case.</p>
      </div>
      <div class="grid md:grid-cols-2 gap-8">
        {services.map((service) => (
          <div class="border-2 border-gray-100 rounded-2xl p-8">
            <div class="w-12 h-12 bg-blue-50 rounded-xl flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-blue-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d={service.icon} />
              </svg>
            </div>
            <h3 class="text-xl font-bold mb-3">{service.title}</h3>
            <p class="text-gray-500 text-lg font-semibold">{service.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="px-4 md:px-20 py-20 md:py-32 bg-gray-50">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <span class="text-orange-500 font-semibold tracking-[0.2em] text-sm uppercase">Unser Prozess</span>
        <h2 class="text-3xl md:text-5xl font-bold mt-4">Vier Schritte zur produktiven KI</h2>
      </div>
      <div class="grid md:grid-cols-2 gap-8">
        {processSteps.map((step) => (
          <div class="bg-white border-2 border-gray-100 rounded-2xl p-8">
            <div class="flex items-center gap-4 mb-6">
              <span class="text-3xl font-bold text-blue-600">{step.step}</span>
              <div>
                <h3 class="text-xl font-bold">{step.title}</h3>
                <span class="text-gray-400 text-sm font-medium">{step.duration}</span>
              </div>
            </div>
            <p class="text-gray-500 text-lg font-semibold mb-6">{step.description}</p>
            <div class="pt-6 border-t border-gray-100">
              <p class="text-sm font-bold text-gray-700 mb-3">Ergebnisse:</p>
              <ul class="space-y-2">
                {step.deliverables.map((deliverable) => (
                  <li class="flex items-center gap-3">
                    <svg class="w-4 h-4 text-green-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                    <span class="text-gray-600 text-sm font-medium">{deliverable}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Who It's For -->
  <section class="px-4 md:px-20 py-20 md:py-32">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <span class="text-orange-500 font-semibold tracking-[0.2em] text-sm uppercase">Für wen</span>
        <h2 class="text-3xl md:text-5xl font-bold mt-4">Entwickelt für Entscheider</h2>
        <p class="text-gray-500 text-lg font-semibold mt-4 max-w-2xl mx-auto">Ob Sie KI zum ersten Mal evaluieren oder bestehende Initiativen skalieren, unsere Beratung holt Sie auf Ihrem Reifegrad ab.</p>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        {audiences.map((audience) => (
          <div class="border-2 border-gray-100 rounded-2xl p-8">
            <h3 class="text-xl font-bold mb-3">{audience.title}</h3>
            <p class="text-gray-500 text-lg font-semibold mb-6">{audience.description}</p>
            <div class="pt-6 border-t border-gray-100">
              <p class="text-sm font-bold text-gray-700 mb-3">Typische Herausforderungen:</p>
              <ul class="space-y-2">
                {audience.challenges.map((challenge) => (
                  <li class="flex items-start gap-3">
                    <svg class="w-4 h-4 text-orange-500 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
                    <span class="text-gray-600 text-sm font-medium">{challenge}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Not Sure Where to Start -->
  <section class="px-4 md:px-20 py-20 md:py-32">
    <div class="max-w-7xl mx-auto">
      <div class="bg-black rounded-2xl p-8 md:p-16 text-center">
        <span class="text-orange-500 font-semibold tracking-[0.2em] text-sm uppercase">Jetzt starten</span>
        <h2 class="text-white text-3xl md:text-5xl font-bold mt-4">Nicht sicher, wo Sie anfangen sollen?</h2>
        <p class="text-white/80 text-lg md:text-xl font-medium mt-4 max-w-3xl mx-auto">Die meisten Unternehmen wissen, dass sie KI brauchen, sind aber unsicher, was realistisch ist, was sich lohnt und wie man typische Fallstricke vermeidet. Genau dafür ist unser Assessment da.</p>
        <a href="https://outlook.office.com/book/IronumCallWithGerrit@ironum1.onmicrosoft.com/?ismsaljsauthenabled" target="_blank" rel="noopener noreferrer"
          class="inline-flex items-center bg-blue-600 text-white rounded-full px-6 py-4 font-medium text-lg hover:bg-blue-700 active:bg-blue-800 transition-all duration-200 min-h-[48px] touch-manipulation mt-8">
          Kostenloses Assessment sichern
        </a>
        <p class="text-white/40 text-sm mt-3">Kostenloses 30-Min-Gespräch · Unverbindlich</p>
      </div>
    </div>
  </section>

  <!-- Industries -->
  <section class="px-4 md:px-20 py-20 md:py-32 bg-gray-50">
    <div class="max-w-7xl mx-auto space-y-8">
      <span class="text-orange-500 font-semibold tracking-[0.2em] text-sm uppercase block">BRANCHEN</span>
      <h2 class="text-3xl md:text-5xl font-bold">Für wen wir das bauen</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <a href="/de/branchen/recht/" class="border-2 border-gray-100 rounded-2xl p-8 bg-white hover:border-blue-200 transition-colors group">
          <h3 class="text-xl font-bold mb-3">Recht</h3>
          <p class="text-gray-500 font-semibold mb-4">KI-Strategie für Kanzleien im Spannungsfeld von Mandantenvertraulichkeit, EU-KI-Verordnung und Dokumentenautomatisierung.</p>
          <span class="text-blue-600 font-semibold inline-flex items-center gap-1 group-hover:gap-2 transition-all">Mehr erfahren <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg></span>
        </a>
        <a href="/de/branchen/fertigung/" class="border-2 border-gray-100 rounded-2xl p-8 bg-white hover:border-blue-200 transition-colors group">
          <h3 class="text-xl font-bold mb-3">Fertigung</h3>
          <p class="text-gray-500 font-semibold mb-4">Industrie-4.0-Readiness-Assessments und KI-Roadmaps für den Mittelstand.</p>
          <span class="text-blue-600 font-semibold inline-flex items-center gap-1 group-hover:gap-2 transition-all">Mehr erfahren <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg></span>
        </a>
        <a href="/de/branchen/gesundheitswesen/" class="border-2 border-gray-100 rounded-2xl p-8 bg-white hover:border-blue-200 transition-colors group">
          <h3 class="text-xl font-bold mb-3">Gesundheitswesen</h3>
          <p class="text-gray-500 font-semibold mb-4">KI-Audits für Gesundheitseinrichtungen mit integriertem Patientendatenschutz und regulatorischer Compliance.</p>
          <span class="text-blue-600 font-semibold inline-flex items-center gap-1 group-hover:gap-2 transition-all">Mehr erfahren <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg></span>
        </a>
        <a href="/de/branchen/finanzdienstleistungen/" class="border-2 border-gray-100 rounded-2xl p-8 bg-white hover:border-blue-200 transition-colors group">
          <h3 class="text-xl font-bold mb-3">Finanzdienstleistungen</h3>
          <p class="text-gray-500 font-semibold mb-4">Technische Audits und Compliance-Assessments für Banken im Umfeld von BaFin, EZB und EU-KI-Verordnung.</p>
          <span class="text-blue-600 font-semibold inline-flex items-center gap-1 group-hover:gap-2 transition-all">Mehr erfahren <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg></span>
        </a>
      </div>
    </div>
  </section>

  <FAQSection items={faqItems} />
  <FinalCTA />
  <Footer />
</Layout>
