---
import Layout from '../../../layouts/Layout.astro';
import Navigation from '../../../components/Navigation.astro';
import PageHero from '../../../components/sections/PageHero.astro';
import FAQSection from '../../../components/sections/FAQSection.astro';
import FinalCTA from '../../../components/FinalCTA.astro';
import Footer from '../../../components/Footer.astro';

const features = [
  {
    title: 'Privates Deployment',
    description: 'Deployment auf Ihrer eigenen Infrastruktur: Azure EU, Hetzner oder On-Premises. Ihre Dokumente verlassen nie Ihre Kontrolle. Kein Datenaustausch mit Modellanbietern.',
    icon: 'M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z',
  },
  {
    title: 'Multi-Format-Unterstützung',
    description: 'Verarbeitung von PDFs, Word-Dokumenten, Excel-Tabellen, E-Mails, Confluence-Seiten, SharePoint-Dateien und mehr. Automatisches OCR für gescannte Dokumente.',
    icon: 'M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z',
  },
  {
    title: 'Echtzeit-Synchronisation',
    description: 'Automatische Dokumentenindexierung bei Dateiänderungen. Anbindung an SharePoint, Confluence, Google Drive oder interne Dateisysteme für stets aktuelle Antworten.',
    icon: 'M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182',
  },
  {
    title: 'Rollenbasierter Zugriff',
    description: 'Bestehende Berechtigungsstrukturen durchsetzen. Nutzer sehen nur Antworten aus Dokumenten, auf die sie Zugriff haben. Integration mit Active Directory und SSO.',
    icon: 'M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z',
  },
  {
    title: 'Open-Source-LLMs',
    description: 'Betrieb von Llama, Mistral oder anderen Open-Source-Modellen. Keine Per-Token-Gebühren, keine Daten an Dritte. Volle Kontrolle über Modellauswahl und Updates.',
    icon: 'M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5',
  },
  {
    title: 'Individuelle Feinabstimmung',
    description: 'Feinabstimmung von Embedding- und Generierungsmodellen auf Ihren Domän-Wortschatz. Verbesserte Genauigkeit für branchenspezifische Terminologie und Dokumentenstrukturen.',
    icon: 'M10.5 6h9.75M10.5 6a1.5 1.5 0 11-3 0m3 0a1.5 1.5 0 10-3 0M3.75 6H7.5m3 12h9.75m-9.75 0a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m-3.75 0H7.5m9-6h3.75m-3.75 0a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m-9.75 0h9.75',
  },
];

const useCases = [
  {
    title: 'Juristische Dokumentenprüfung',
    description: 'Eine mittelständische deutsche Kanzlei verarbeitet monatlich Tausende von Verträgen. Mit Ironum RAG durchsuchen Anwälte die gesamte Vertragsdatenbank in natürlicher Sprache, finden relevante Klauseln, identifizieren Risiken und vergleichen Konditionen in Sekunden statt Stunden.',
    stat: '80 %',
    statLabel: 'schnellere Dokumentenprüfung',
  },
  {
    title: 'Interne Wissensdatenbank',
    description: 'Ein europäischer Hersteller mit über 2.000 Mitarbeitenden setzt RAG für technische Dokumentation, HR-Richtlinien und Schulungsmaterialien ein. Neue Mitarbeitende erhalten sofort präzise Antworten. Support-Tickets sinken, da Teams sich selbst aus einer einheitlichen Wissensschicht bedienen.',
    stat: '60 %',
    statLabel: 'weniger interne Tickets',
  },
  {
    title: 'Compliance & Audit-Prüfungen',
    description: 'Ein Finanzdienstleister nutzt RAG zur Überwachung regulatorischer Dokumente und zum Abgleich mit internen Richtlinien. Compliance-Beauftragte erhalten sofortige Alerts bei Regulierungsänderungen und können die Richtlinienkonformität über Hunderte von Dokumenten automatisch prüfen.',
    stat: '10x',
    statLabel: 'schnellere Compliance-Prüfungen',
  },
];

const faqItems = [
  {
    question: 'Was ist RAG und wie unterscheidet es sich von Feinabstimmung?',
    answer: 'Retrieval-Augmented Generation (RAG) verbindet ein LLM zur Abfragezeit mit Ihrer Dokumentenbasis. Anstatt das Modell auf Ihren Daten zu trainieren (Feinabstimmung), ruft RAG relevante Passagen ab und speist sie als Kontext in das Modell ein. Das bedeutet: Ihre Antworten sind immer in aktuellen Dokumenten verankert, Halluzinationen werden drastisch reduziert und Sie können Wissen sofort aktualisieren, ohne neu zu trainieren. RAG ist die richtige Wahl, wenn Sie präzise, quellenbasierte Antworten aus einer sich ändernden Dokumentenbasis benötigen.',
  },
  {
    question: 'Wie stellen Sie Datenschutz und DSGVO-Konformität sicher?',
    answer: 'Ihre Dokumente werden ausschließlich auf Infrastruktur verarbeitet und gespeichert, die Sie kontrollieren: entweder Ihre eigenen Server, Azure EU-Regionen oder deutsche Hetzner-Infrastruktur. Wir senden Ihre Daten nie an Drittanbieter-Modellanbieter. Bei Verwendung von Open-Source-LLMs läuft die gesamte Pipeline auf Ihrer Hardware. Alle Datenverarbeitung wird durch einen Standard-DSGVO-Auftragsverarbeitungsvertrag (AVV) abgedeckt.',
  },
  {
    question: 'Wie lange dauert das Deployment?',
    answer: 'Ein produktionsreifes RAG-System benötigt typischerweise 4 bis 8 Wochen vom Kickoff bis zum Launch. Dies umfasst den Aufbau der Dokumenten-Ingestion-Pipeline, die Konfiguration des Embedding-Modells, das Retrieval-Tuning, das UI-Deployment und die Benutzerakzeptanztests. Ein funktionierender Proof-of-Concept mit Ihren echten Dokumenten kann bereits in 2 Wochen bereit sein.',
  },
  {
    question: 'Welche Dokumentformate werden unterstützt?',
    answer: 'Wir unterstützen PDF, DOCX, XLSX, PPTX, HTML, Markdown, Plain Text, E-Mails (EML, MSG) und strukturierte Datenformate (CSV, JSON). Gescannte Dokumente werden per OCR verarbeitet. Konnektoren sind verfügbar für SharePoint, Confluence, Google Drive, Notion und individuelle APIs.',
  },
  {
    question: 'Wie ist die Preisgestaltung?',
    answer: 'Die Preisgestaltung hängt vom Deployment-Modell, Dokumentenvolumen und dem gewählten LLM-Anbieter ab. On-Premises-Deployments mit Open-Source-Modellen haben keine Per-Query-Kosten. Sie zahlen nur für Infrastruktur und unsere Setup- und Wartungsleistungen. Cloud-API-Deployments beinhalten durchgereichte Token-Kosten. Wir erstellen transparente, aufgeschlüsselte Angebote nach einem ersten Scoping-Gespräch.',
  },
];

const structuredData = [
  {
    "@type": "Service",
    "@id": "https://www.ironum.com/de/dienstleistungen/enterprise-rag/#service",
    "name": "Enterprise RAG-Lösungen",
    "description": "Verwandeln Sie verteilte Dokumente in eine durchsuchbare, private Wissensdatenbank mit Retrieval-Augmented Generation. DSGVO-konform, deployed auf Ihrer Infrastruktur.",
    "provider": { "@id": "https://www.ironum.com/#organization" },
    "areaServed": { "@type": "Place", "name": "Europe" },
    "serviceType": "Enterprise RAG",
    "inLanguage": "de"
  }
];

const breadcrumbs = [
  { label: 'Startseite', href: '/de' },
  { label: 'Dienstleistungen', href: '/de/dienstleistungen' },
  { label: 'Enterprise RAG', href: '/de/dienstleistungen/enterprise-rag' },
];
---

<Layout
  locale="de"
  title="Enterprise RAG-Lösungen | Private Dokumenten-KI | Ironum"
  description="Verwandeln Sie Ihre Dokumente in verwertbare Intelligenz mit Retrieval-Augmented Generation. Privates Deployment, DSGVO-konform, Open-Source-LLMs. Auf Ihrer Infrastruktur."
  breadcrumbs={breadcrumbs}
  structuredData={structuredData}
>
  <Navigation />

  <PageHero
    eyebrow="ENTERPRISE RAG"
    title="Verwandeln Sie Ihre Dokumente in verwertbare Intelligenz"
    subtitle="Retrieval-Augmented Generation auf Ihrer Infrastruktur. Durchsuchen Sie Tausende von Dokumenten in natürlicher Sprache, mit Antworten, die in Ihren echten Daten verankert sind."
  />

  <!-- Problem Section -->
  <section class="px-4 md:px-20 py-20 md:py-32">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <span class="text-orange-500 font-semibold tracking-[0.2em] text-sm uppercase">Das Problem</span>
        <h2 class="text-3xl md:text-5xl font-bold mt-4">Ihr Wissen ist eingesperrt</h2>
        <p class="text-gray-500 text-lg font-semibold mt-4 max-w-2xl mx-auto">Europäische Unternehmen sitzen auf riesigen Dokumentenarchiven, aber die Wertschöpfung daraus ist schmerzhaft langsam und zunehmend riskant mit öffentlichen KI-Tools.</p>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="border-2 border-gray-100 rounded-2xl p-8">
          <div class="w-12 h-12 bg-red-50 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-red-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 7.5l-.625 10.632a2.25 2.25 0 01-2.247 2.118H6.622a2.25 2.25 0 01-2.247-2.118L3.75 7.5m6 4.125l2.25 2.25m0 0l2.25 2.25M12 13.875l2.25-2.25M12 13.875l-2.25 2.25M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z" /></svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Verstreutes Wissen</h3>
          <p class="text-gray-500 text-lg font-semibold">Kritische Informationen vergraben in SharePoint, Dateiservern, E-Mail und Confluence. Mitarbeitende verbringen 20 % ihrer Arbeitswoche mit der Suche nach Informationen.</p>
        </div>
        <div class="border-2 border-gray-100 rounded-2xl p-8">
          <div class="w-12 h-12 bg-red-50 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-red-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Langsame Suche, verpasste Erkenntnisse</h3>
          <p class="text-gray-500 text-lg font-semibold">Stichwortsuche versagt bei komplexen Anfragen. Teams verpassen Zusammenhänge zwischen Dokumenten, weil traditionelle Suche Kontext und Bedeutung nicht verstehen kann.</p>
        </div>
        <div class="border-2 border-gray-100 rounded-2xl p-8">
          <div class="w-12 h-12 bg-red-50 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-red-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" /></svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Datensicherheitsrisiko</h3>
          <p class="text-gray-500 text-lg font-semibold">Das Hochladen vertraulicher Dokumente zu ChatGPT oder anderen öffentlichen KI-Tools verstößt gegen die DSGVO und gefährdet Geschäftsgeheimnisse. 65 % der Mitarbeitenden geben zu, unautorisierte KI-Tools bei der Arbeit zu nutzen.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Solution Section -->
  <section class="px-4 md:px-20 py-20 md:py-32 bg-gray-50">
    <div class="max-w-7xl mx-auto">
      <div class="grid md:grid-cols-2 gap-16 items-center">
        <div>
          <span class="text-orange-500 font-semibold tracking-[0.2em] text-sm uppercase">Die Lösung</span>
          <h2 class="text-3xl md:text-5xl font-bold mt-4">Privates RAG auf Ihrer Infrastruktur</h2>
          <p class="text-gray-500 text-lg font-semibold mt-6">Ironum deployt eine vollständige Retrieval-Augmented-Generation-Pipeline auf Infrastruktur, die Sie kontrollieren. Ihre Mitarbeitenden durchsuchen Ihre gesamte Dokumentenbasis in natürlicher Sprache und erhalten präzise, quellenbasierte Antworten, ohne dass Daten Ihre Umgebung verlassen.</p>
          <ul class="mt-8 space-y-4">
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-green-500 mt-1 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              <span class="text-gray-700 font-medium">Semantische Suche über alle Dokumenttypen, nicht nur Stichwortabgleich</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-green-500 mt-1 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              <span class="text-gray-700 font-medium">Jede Antwort mit Quelldokumenten verknüpft für volle Nachvollziehbarkeit</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-green-500 mt-1 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              <span class="text-gray-700 font-medium">Deploybar auf Azure EU, Hetzner Deutschland oder Ihrer eigenen Hardware</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-green-500 mt-1 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              <span class="text-gray-700 font-medium">Bereit für Transparenz- und Dokumentationsanforderungen der EU-KI-Verordnung</span>
            </li>
          </ul>
        </div>
        <div class="bg-white border-2 border-gray-100 rounded-2xl p-8">
          <div class="space-y-6">
            <div class="flex items-center gap-4 pb-6 border-b border-gray-100">
              <div class="w-10 h-10 bg-blue-50 rounded-lg flex items-center justify-center shrink-0">
                <span class="text-blue-600 font-bold text-sm">1</span>
              </div>
              <div>
                <h4 class="font-bold">Aufnehmen</h4>
                <p class="text-gray-500 text-sm">Dokumente werden in Chunks aufgeteilt, eingebettet und in einer Vektordatenbank auf Ihrer Infrastruktur gespeichert.</p>
              </div>
            </div>
            <div class="flex items-center gap-4 pb-6 border-b border-gray-100">
              <div class="w-10 h-10 bg-blue-50 rounded-lg flex items-center justify-center shrink-0">
                <span class="text-blue-600 font-bold text-sm">2</span>
              </div>
              <div>
                <h4 class="font-bold">Abrufen</h4>
                <p class="text-gray-500 text-sm">Nutzeranfragen werden per semantischer Ähnlichkeit mit Ihren Dokumenten-Embeddings abgeglichen.</p>
              </div>
            </div>
            <div class="flex items-center gap-4 pb-6 border-b border-gray-100">
              <div class="w-10 h-10 bg-blue-50 rounded-lg flex items-center justify-center shrink-0">
                <span class="text-blue-600 font-bold text-sm">3</span>
              </div>
              <div>
                <h4 class="font-bold">Generieren</h4>
                <p class="text-gray-500 text-sm">Das LLM synthetisiert eine Antwort aus den abgerufenen Passagen und gibt Quellen an.</p>
              </div>
            </div>
            <div class="flex items-center gap-4">
              <div class="w-10 h-10 bg-blue-50 rounded-lg flex items-center justify-center shrink-0">
                <span class="text-blue-600 font-bold text-sm">4</span>
              </div>
              <div>
                <h4 class="font-bold">Verifizieren</h4>
                <p class="text-gray-500 text-sm">Nutzer klicken durch zu den Originaldokumenten zur Verifizierung und Vertrauensbildung.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Features Grid -->
  <section class="px-4 md:px-20 py-20 md:py-32">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <span class="text-orange-500 font-semibold tracking-[0.2em] text-sm uppercase">Funktionen</span>
        <h2 class="text-3xl md:text-5xl font-bold mt-4">Enterprise-RAG für den Mittelstand</h2>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {features.map((feature) => (
          <div class="border-2 border-gray-100 rounded-2xl p-8">
            <div class="w-12 h-12 bg-blue-50 rounded-xl flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-blue-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d={feature.icon} />
              </svg>
            </div>
            <h3 class="text-xl font-bold mb-3">{feature.title}</h3>
            <p class="text-gray-500 text-lg font-semibold">{feature.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Use Cases -->
  <section class="px-4 md:px-20 py-20 md:py-32 bg-gray-50">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <span class="text-orange-500 font-semibold tracking-[0.2em] text-sm uppercase">Anwendungsfälle</span>
        <h2 class="text-3xl md:text-5xl font-bold mt-4">RAG in der Praxis</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        {useCases.map((useCase) => (
          <div class="bg-white border-2 border-gray-100 rounded-2xl p-8">
            <div class="mb-6">
              <span class="text-4xl md:text-5xl font-bold text-blue-600">{useCase.stat}</span>
              <p class="text-gray-500 font-semibold mt-1">{useCase.statLabel}</p>
            </div>
            <h3 class="text-xl font-bold mb-3">{useCase.title}</h3>
            <p class="text-gray-500 text-lg font-semibold">{useCase.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Industries -->
  <section class="px-4 md:px-20 py-20 md:py-32 bg-gray-50">
    <div class="max-w-7xl mx-auto space-y-8">
      <span class="text-orange-500 font-semibold tracking-[0.2em] text-sm uppercase block">BRANCHEN</span>
      <h2 class="text-3xl md:text-5xl font-bold">Für wen wir das bauen</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <a href="/de/branchen/recht/" class="border-2 border-gray-100 rounded-2xl p-8 bg-white hover:border-blue-200 transition-colors group">
          <h3 class="text-xl font-bold mb-3">Recht</h3>
          <p class="text-gray-500 font-semibold mb-4">Vertragsprüfung, Compliance-Analyse und juristische Recherche über Tausende vertraulicher Dokumente.</p>
          <span class="text-blue-600 font-semibold inline-flex items-center gap-1 group-hover:gap-2 transition-all">Mehr erfahren <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg></span>
        </a>
        <a href="/de/branchen/fertigung/" class="border-2 border-gray-100 rounded-2xl p-8 bg-white hover:border-blue-200 transition-colors group">
          <h3 class="text-xl font-bold mb-3">Fertigung</h3>
          <p class="text-gray-500 font-semibold mb-4">Durchsuchbare technische Dokumentation, Wartungsprotokolle und Qualitätsstandards für Produktionsteams.</p>
          <span class="text-blue-600 font-semibold inline-flex items-center gap-1 group-hover:gap-2 transition-all">Mehr erfahren <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg></span>
        </a>
        <a href="/de/branchen/gesundheitswesen/" class="border-2 border-gray-100 rounded-2xl p-8 bg-white hover:border-blue-200 transition-colors group">
          <h3 class="text-xl font-bold mb-3">Gesundheitswesen</h3>
          <p class="text-gray-500 font-semibold mb-4">Klinische Protokollsuche und institutionelles Wissensmanagement mit Patientendatensouveränität.</p>
          <span class="text-blue-600 font-semibold inline-flex items-center gap-1 group-hover:gap-2 transition-all">Mehr erfahren <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg></span>
        </a>
        <a href="/de/branchen/finanzdienstleistungen/" class="border-2 border-gray-100 rounded-2xl p-8 bg-white hover:border-blue-200 transition-colors group">
          <h3 class="text-xl font-bold mb-3">Finanzdienstleistungen</h3>
          <p class="text-gray-500 font-semibold mb-4">Regulatorische Dokumentenanalyse, DIN-Normen-Suche und Compliance-Archiv-Retrieval für Banken.</p>
          <span class="text-blue-600 font-semibold inline-flex items-center gap-1 group-hover:gap-2 transition-all">Mehr erfahren <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg></span>
        </a>
      </div>
    </div>
