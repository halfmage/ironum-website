---
import Layout from '../../../layouts/Layout.astro';
import Navigation from '../../../components/Navigation.astro';
import PageHero from '../../../components/sections/PageHero.astro';
import FAQSection from '../../../components/sections/FAQSection.astro';
import FinalCTA from '../../../components/FinalCTA.astro';
import Footer from '../../../components/Footer.astro';

const features = [
  {
    title: 'Visueller Workflow-Builder',
    description: 'Entwerfen Sie komplexe Automatisierungsabläufe mit einem Drag-and-Drop-Canvas. Kein Coding für Standard-Workflows, mit vollem Code-Zugang, wenn Sie ihn brauchen.',
    icon: 'M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z',
  },
  {
    title: 'Über 400 Integrationen',
    description: 'Anbindung an Slack, HubSpot, Salesforce, SAP, Microsoft 365, Google Workspace, Datenbanken und Hunderte weitere. Individuelle API-Integrationen für interne Tools.',
    icon: 'M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m13.35-.622l1.757-1.757a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244',
  },
  {
    title: 'Self-Hosted & DSGVO-konform',
    description: 'n8n läuft auf Ihren eigenen Servern oder in Ihrer Private Cloud. Alle Workflow-Daten, Credentials und Ausführungsprotokolle bleiben in Ihrer Infrastruktur. Keine Daten verlassen Ihre Umgebung.',
    icon: 'M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z',
  },
  {
    title: 'KI-gestützte Orchestrierung',
    description: 'Integrieren Sie LLMs direkt in Workflows. E-Mails klassifizieren, Daten aus Dokumenten extrahieren, Berichte generieren und Entscheidungen routen, alles automatisiert mit KI.',
    icon: 'M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z',
  },
  {
    title: 'Fehlerbehandlung & Monitoring',
    description: 'Integrierte Retry-Logik, Fehler-Branches und Alerting. Benachrichtigung bei Workflow-Fehlern mit automatischer Wiederherstellung ohne manuellen Eingriff.',
    icon: 'M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z',
  },
  {
    title: 'Skalierbare Architektur',
    description: 'Verarbeitung von Tausenden Workflow-Ausführungen pro Stunde. Horizontale Skalierung über mehrere Worker. Queue-basierte Ausführung für Hochvolumen-Verarbeitung.',
    icon: 'M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5m.75-9l3-3 2.148 2.148A12.061 12.061 0 0116.5 7.605',
  },
];

const useCases = [
  {
    title: 'Rechnungsverarbeitung',
    description: 'Eingehende Rechnungen werden automatisch aus E-Mails extrahiert, per KI geparst, gegen Bestellungen in Ihrem ERP validiert und zur Freigabe weitergeleitet. Von Tagen zu Minuten.',
    before: 'Manuelle Dateneingabe, 3 Tage Bearbeitungszeit',
    after: 'Automatische Extraktion, Bearbeitung am selben Tag',
  },
  {
    title: 'E-Mail-Triage & Routing',
    description: 'KI klassifiziert eingehende E-Mails nach Absicht, Dringlichkeit und Abteilung. Support-Anfragen werden kategorisiert, Kundendaten aus dem CRM angereichert und Tickets automatisch in der richtigen Queue erstellt.',
    before: 'Manuelles Sortieren, übersehene Prioritäten',
    after: 'KI-Klassifikation, sofortiges Routing',
  },
  {
    title: 'Systemübergreifende Datensynchronisation',
    description: 'Halten Sie CRM, ERP, HR und Projektmanagement-Tools synchron. Wenn ein Deal in Salesforce abgeschlossen wird, aktualisiert sich automatisch SAP, ein Projekt wird in Monday.com erstellt und das Team in Slack benachrichtigt.',
    before: 'Manuelle Updates, Dateninkonsistenzen',
    after: 'Echtzeit-Sync, Single Source of Truth',
  },
];

const faqItems = [
  {
    question: 'Was ist n8n und warum setzen Sie es ein?',
    answer: 'n8n ist eine Open-Source-Workflow-Automatisierungsplattform mit einem visuellen Builder und über 400 Integrationen. Wir haben uns für n8n entschieden, weil es vollständig self-hosted betrieben werden kann (kritisch für die DSGVO), kein Vendor Lock-in entsteht, Custom-Code-Nodes für komplexe Logik unterstützt und nativ mit KI-Modellen integriert. Anders als Zapier oder Make verlassen Ihre Workflow-Daten und Credentials nie Ihre Infrastruktur.',
  },
  {
    question: 'Können Sie Workflows automatisieren, die KI-Entscheidungen beinhalten?',
    answer: 'Ja. Wir integrieren LLMs direkt in n8n-Workflows für Aufgaben wie Dokumentenklassifikation, Datenextraktion, Sentiment-Analyse, Content-Generierung und Entscheidungs-Routing. Die KI-Komponenten laufen auf derselben privaten Infrastruktur wie Ihre Workflows, sodass sensible Daten sicher bleiben.',
  },
  {
    question: 'Wie gehen Sie mit Fehlern und Monitoring um?',
    answer: 'Jeder Workflow umfasst Fehlerbehandlungs-Branches, automatische Retries mit exponentiellem Backoff und Alerting per E-Mail, Slack oder Ihrem bevorzugten Monitoring-Tool. Wir richten außerdem Dashboards für die Ausführungsüberwachung ein, damit Ihr Team volle Transparenz über die Workflow-Performance hat.',
  },
  {
    question: 'Welche Systeme können Sie integrieren?',
    answer: 'n8n hat native Konnektoren für über 400 Tools, darunter Microsoft 365, Google Workspace, Salesforce, HubSpot, SAP, Slack, Jira, Datenbanken (PostgreSQL, MySQL, MongoDB) und mehr. Für interne oder Legacy-Systeme bauen wir individuelle API-Integrationen oder nutzen Webhooks. Wenn es eine API hat, können wir es anbinden.',
  },
  {
    question: 'Wie ist die Preisgestaltung für Workflow-Automatisierung?',
    answer: 'Da n8n Open Source ist, fallen keine Pro-Workflow- oder Pro-Ausführungs-Lizenzgebühren an. Sie zahlen für Infrastruktur-Hosting und unsere Leistungen: initiales Workflow-Design, Implementierung, Testing und laufende Wartung. Das ergibt typischerweise 60-80 % niedrigere Gesamtkosten im Vergleich zu proprietären Plattformen wie Zapier oder Make im Unternehmenseinsatz.',
  },
];

const structuredData = [
  {
    "@type": "Service",
    "@id": "https://www.ironum.com/de/dienstleistungen/workflow-automatisierung/#service",
    "name": "Workflow-Automatisierung mit n8n",
    "description": "Geschäftsprozesse automatisieren mit self-hosted n8n-Workflows. Über 400 Integrationen, KI-gestützte Orchestrierung, DSGVO-konform. Kein Vendor Lock-in.",
    "provider": { "@id": "https://www.ironum.com/#organization" },
    "areaServed": { "@type": "Place", "name": "Europe" },
    "serviceType": "Workflow-Automatisierung",
    "inLanguage": "de"
  }
];

const breadcrumbs = [
  { label: 'Startseite', href: '/de' },
  { label: 'Dienstleistungen', href: '/de/dienstleistungen' },
  { label: 'Workflow-Automatisierung', href: '/de/dienstleistungen/workflow-automatisierung' },
];
---

<Layout
  locale="de"
  title="Workflow-Automatisierung mit n8n | DSGVO-konform | Ironum"
  description="Geschäftsprozesse automatisieren mit self-hosted n8n-Workflows. Über 400 Integrationen, KI-gestützte Orchestrierung, kein Vendor Lock-in. DSGVO-konform, europäisches Hosting."
  breadcrumbs={breadcrumbs}
  structuredData={structuredData}
>
  <Navigation />

  <PageHero
    eyebrow="WORKFLOW-AUTOMATISIERUNG"
    title="Geschäftsprozesse automatisieren ohne Vendor Lock-in"
    subtitle="Self-hosted n8n-Workflows, die Ihre Tools verbinden, KI integrieren und auf Infrastruktur laufen, die Sie kontrollieren. Open Source, DSGVO-konform, unbegrenzt anpassbar."
  />

  <!-- Problem Section -->
  <section class="px-4 md:px-20 py-20 md:py-32">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <span class="text-orange-500 font-semibold tracking-[0.2em] text-sm uppercase">Das Problem</span>
        <h2 class="text-3xl md:text-5xl font-bold mt-4">Manuelle Arbeit frisst Ihre Margen</h2>
        <p class="text-gray-500 text-lg font-semibold mt-4 max-w-2xl mx-auto">Europäische Mittelständler verlieren durchschnittlich 30 % der produktiven Zeit durch repetitive Aufgaben, die automatisiert werden sollten. Legacy-Ansätze schaffen neue Probleme.</p>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="border-2 border-gray-100 rounded-2xl p-8">
          <div class="w-12 h-12 bg-red-50 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-red-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Manuelle Prozesse</h3>
          <p class="text-gray-500 text-lg font-semibold">Dateneingabe, E-Mail-Sortierung, Berichtserstellung, Systemupdates. Ihr Team verbringt Stunden mit Aufgaben, die eine Maschine in Sekunden erledigen könnte.</p>
        </div>
        <div class="border-2 border-gray-100 rounded-2xl p-8">
          <div class="w-12 h-12 bg-red-50 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-red-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 0v3.75m-16.5-3.75v3.75m16.5 0v3.75C20.25 16.153 16.556 18 12 18s-8.25-1.847-8.25-4.125v-3.75m16.5 0c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125" /></svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Datensilos</h3>
          <p class="text-gray-500 text-lg font-semibold">Informationen gefangen in isolierten Systemen. CRM, ERP, HR und Projekttools, die nicht miteinander kommunizieren, führen zu Doppelarbeit und Fehlern.</p>
        </div>
        <div class="border-2 border-gray-100 rounded-2xl p-8">
          <div class="w-12 h-12 bg-red-50 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-red-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z" /></svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Teure proprietäre Tools</h3>
          <p class="text-gray-500 text-lg font-semibold">Zapier und Make berechnen pro Ausführung. Im Unternehmenseinsatz explodieren die Kosten schnell, und Ihre Workflow-Daten liegen auf US-Servern außerhalb des DSGVO-Schutzes.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Solution Section -->
  <section class="px-4 md:px-20 py-20 md:py-32 bg-gray-50">
    <div class="max-w-7xl mx-auto">
      <div class="grid md:grid-cols-2 gap-16 items-center">
        <div>
          <span class="text-orange-500 font-semibold tracking-[0.2em] text-sm uppercase">Die Lösung</span>
          <h2 class="text-3xl md:text-5xl font-bold mt-4">n8n: Open-Source-Automatisierung, die skaliert</h2>
          <p class="text-gray-500 text-lg font-semibold mt-6">Wir deployen und konfigurieren n8n, die führende Open-Source-Workflow-Automatisierungsplattform, auf Ihrer eigenen Infrastruktur. Gestalten Sie Workflows visuell, verbinden Sie über 400 Tools und integrieren Sie KI für intelligente Automatisierung. Keine Pro-Ausführungs-Gebühren, kein Vendor Lock-in, volle DSGVO-Konformität.</p>
          <div class="mt-8 flex flex-wrap gap-4">
            <a href="https://outlook.office.com/book/IronumCallWithGerrit@ironum1.onmicrosoft.com/?ismsaljsauthenabled" target="_blank" rel="noopener noreferrer"
              class="inline-flex items-center bg-blue-600 text-white rounded-full px-6 py-4 font-medium text-lg hover:bg-blue-700 active:bg-blue-800 transition-all duration-200 min-h-[48px] touch-manipulation">
              Demo vereinbaren
            </a>
          </div>
        </div>
        <div class="space-y-6">
          <div class="bg-white border-2 border-gray-100 rounded-2xl p-6">
            <div class="flex items-center gap-4">
              <span class="text-3xl font-bold text-blue-600">0</span>
              <div>
                <h4 class="font-bold">Pro-Ausführungs-Gebühren</h4>
                <p class="text-gray-500 text-sm">Open-Source-Lizenz. Unbegrenzte Workflows.</p>
              </div>
            </div>
          </div>
          <div class="bg-white border-2 border-gray-100 rounded-2xl p-6">
            <div class="flex items-center gap-4">
              <span class="text-3xl font-bold text-blue-600">400+</span>
              <div>
                <h4 class="font-bold">Native Integrationen</h4>
                <p class="text-gray-500 text-sm">Plus individuelle API-Anbindungen für jedes System.</p>
              </div>
            </div>
          </div>
          <div class="bg-white border-2 border-gray-100 rounded-2xl p-6">
            <div class="flex items-center gap-4">
              <span class="text-3xl font-bold text-blue-600">100 %</span>
              <div>
                <h4 class="font-bold">Datensouveränität</h4>
                <p class="text-gray-500 text-sm">Self-hosted auf Ihrer Infrastruktur. DSGVO by Design.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Features Grid -->
  <section class="px-4 md:px-20 py-20 md:py-32">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <span class="text-orange-500 font-semibold tracking-[0.2em] text-sm uppercase">Funktionen</span>
        <h2 class="text-3xl md:text-5xl font-bold mt-4">Gebaut für Unternehmens-Workflows</h2>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {features.map((feature) => (
          <div class="border-2 border-gray-100 rounded-2xl p-8">
            <div class="w-12 h-12 bg-blue-50 rounded-xl flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-blue-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d={feature.icon} />
              </svg>
            </div>
            <h3 class="text-xl font-bold mb-3">{feature.title}</h3>
            <p class="text-gray-500 text-lg font-semibold">{feature.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Use Cases -->
  <section class="px-4 md:px-20 py-20 md:py-32 bg-gray-50">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <span class="text-orange-500 font-semibold tracking-[0.2em] text-sm uppercase">Anwendungsfälle</span>
        <h2 class="text-3xl md:text-5xl font-bold mt-4">Automatisierung in der Praxis</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        {useCases.map((useCase) => (
          <div class="bg-white border-2 border-gray-100 rounded-2xl p-8">
            <h3 class="text-xl font-bold mb-3">{useCase.title}</h3>
            <p class="text-gray-500 text-lg font-semibold mb-6">{useCase.description}</p>
            <div class="space-y-3 pt-6 border-t border-gray-100">
              <div class="flex items-start gap-3">
                <svg class="w-5 h-5 text-red-400 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                <span class="text-gray-500 text-sm font-medium">{useCase.before}</span>
              </div>
              <div class="flex items-start gap-3">
                <svg class="w-5 h-5 text-green-500 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                <span class="text-gray-700 text-sm font-medium">{useCase.after}</span>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Industries -->
  <section class="px-4 md:px-20 py-20 md:py-32 bg-gray-50">
    <div class="max-w-7xl mx-auto space-y-8">
      <span class="text-orange-500 font-semibold tracking-[0.2em] text-sm uppercase block">BRANCHEN</span>
      <h2 class="text-3xl md:text-5xl font-bold">Für wen wir das bauen</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <a href="/de/branchen/fertigung/" class="border-2 border-gray-100 rounded-2xl p-8 bg-white hover:border-blue-200 transition-colors group">
          <h3 class="text-xl font-bold mb-3">Fertigung</h3>
          <p class="text-gray-500 font-semibold mb-4">ERP, MES und Produktionssysteme verbinden für automatisiertes Reporting, Auftragsabwicklung und abteilungsübergreifende Datenflüsse.</p>
          <span class="text-blue-600 font-semibold inline-flex items-center gap-1 group-hover:gap-2 transition-all">Mehr erfahren <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg></span>
        </a>
        <a href="/de/branchen/finanzdienstleistungen/" class="border-2 border-gray-100 rounded-2xl p-8 bg-white hover:border-blue-200 transition-colors group">
          <h3 class="text-xl font-bold mb-3">Finanzdienstleistungen</h3>
          <p class="text-gray-500 font-semibold mb-4">KYC/AML-Screening, Transaktionsüberwachung und regulatorisches Reporting mit vollständigen Audit-Trails automatisieren.</p>
          <span class="text-blue-600 font-semibold inline-flex items-center gap-1 group-hover:gap-2 transition-all">Mehr erfahren <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg></span>
        </a>
        <a href="/de/branchen/öffentlicher-sektor/" class="border-2 border-gray-100 rounded-2xl p-8 bg-white hover:border-blue-200 transition-colors group">
          <h3 class="text-xl font-bold mb-3">Öffentlicher Sektor</h3>
          <p class="text-gray-500 font-semibold mb-4">Dokumentenverarbeitung, Genehmigungsanträge und behördenübergreifende Workflows auf souveräner Infrastruktur.</p>
          <span class="text-blue-600 font-semibold inline-flex items-center gap-1 group-hover:gap-2 transition-all">Mehr erfahren <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg></span>
        </a>
      </div>
    </div>
  </section>

  <FAQSection items={faqItems} />
  <FinalCTA />
  <Footer />
</Layout>
