---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import PageHero from '../../components/sections/PageHero.astro';
import Footer from '../../components/Footer.astro';
---

<Layout
  locale="de"
  title="Vielen Dank | Ironum"
  description="Ihre Nachricht ist eingegangen. Wir antworten innerhalb eines Werktages."
  noindex={true}
>
  <Navigation />

  <PageHero
    eyebrow="NACHRICHT ERHALTEN"
    title="Danke — wir melden uns innerhalb eines Werktages"
    subtitle="In der Zwischenzeit finden Sie hier aktuelle Beiträge zu EU AI Act und souveräner KI-Infrastruktur, oder buchen Sie direkt ein 30-minütiges Gespräch mit Gerrit."
    ctaText="Gespräch mit Gerrit buchen"
    ctaLink="https://outlook.office.com/book/IronumDiscoveryCall1@ironum1.onmicrosoft.com/?ismsaljsauthenabled"
  />

  <section class="px-4 md:px-20 py-20 md:py-32">
    <div class="max-w-3xl mx-auto text-center space-y-6">
      <h2 class="text-2xl md:text-3xl font-bold">Was als Nächstes passiert</h2>
      <p class="text-gray-500 text-lg font-semibold">
        Gerrit liest jede Nachricht persönlich. Sie hören von <a href="mailto:info@ironum.com" class="text-blue-600 hover:underline">info@ironum.com</a> innerhalb eines Werktages &mdash; in der Regel mit ein paar Rückfragen oder einem Terminvorschlag.
      </p>
      <p class="text-gray-500 text-lg font-semibold">
        Falls Ihre Frage zeitkritisch ist, erreichen Sie uns auch telefonisch unter <a href="tel:+4915758539892" class="text-blue-600 hover:underline">+49 157 585 39892</a> (Mo&ndash;Fr, 9:00&ndash;18:00 Uhr MEZ).
      </p>
      <div class="pt-8">
        <a href="/de/ressourcen/blog/" class="inline-block text-blue-600 font-semibold hover:underline">Zu unseren neuesten Blogbeiträgen &rarr;</a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
