---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import Hero from '../../components/Hero.astro';
import ServiceCard from '../../components/cards/ServiceCard.astro';
import Infrastructure from '../../components/Infrastructure.astro';
import Impacts from '../../components/Impacts.astro';
import Testimonials from '../../components/Testimonials.astro';
import ProcessSteps from '../../components/sections/ProcessSteps.astro';
import FinalCTA from '../../components/FinalCTA.astro';
import Footer from '../../components/Footer.astro';
import BlogPostCard from '../../components/cards/BlogPostCard.astro';
import { getCollection } from 'astro:content';
import { useTranslations } from '../../i18n/utils';

const t = useTranslations('de');

const allPosts = (await getCollection('blog'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());

const dePosts = allPosts.filter(p => p.data.locale === 'de');
const latestPosts = (dePosts.length >= 3 ? dePosts : allPosts).slice(0, 3);
const blogBasePath = dePosts.length > 0 ? '/de/ressourcen/blog/' : '/resources/blog/';
---

<Layout locale="de">
  <Navigation />
  <Hero />

  <!-- Vertraut von -->
  <section class="px-4 md:px-20 py-12 md:py-16 border-b border-gray-100">
    <div class="max-w-7xl mx-auto">
      <p class="text-center text-gray-400 text-sm font-semibold uppercase tracking-[0.2em] mb-8">{t.homepage.trustedBy}</p>
      <div class="flex flex-wrap justify-center items-center gap-10 md:gap-16">
        <img src="/logos/learnslice.png" alt="LearnSlice" class="h-20 max-w-[200px] w-auto object-contain" loading="lazy" />
        <img src="/logos/fh-dortmund.svg" alt="FH Dortmund" class="h-12 max-w-[180px] w-auto object-contain" loading="lazy" />
        <img src="/logos/smella.png" alt="Smella" class="h-12 max-w-[160px] w-auto object-contain" loading="lazy" />
        <img src="/logos/ute-becker.svg" alt="Ute Becker Ernährungsberatung" class="h-12 max-w-[180px] w-auto object-contain" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- Die Herausforderung -->
  <section class="px-4 md:px-20 py-20 md:py-32">
    <div class="max-w-7xl mx-auto space-y-8">
      <span class="text-orange-500 font-semibold tracking-[0.2em] text-sm uppercase block">{t.homepage.problemEyebrow}</span>
      <h2 class="text-3xl md:text-5xl xl:text-7xl font-bold">{t.homepage.problemTitle}</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 pt-4">
        {t.homepage.problemCards.map(card => (
          <div class="border-2 border-gray-100 rounded-2xl p-6 md:p-8">
            <h3 class="text-2xl font-bold mb-3">{card.title}</h3>
            <p class="text-gray-500 text-lg font-semibold">{card.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Dienstleistungen Übersicht -->
  <section class="px-4 md:px-20 py-20 md:py-32 max-w-7xl mx-auto space-y-8">
    <span class="text-orange-500 font-semibold tracking-[0.2em] text-sm uppercase block">{t.homepage.servicesEyebrow}</span>
    <h2 class="text-3xl md:text-5xl xl:text-7xl font-bold">{t.homepage.servicesTitle}</h2>
    <p class="text-gray-500 text-lg font-semibold max-w-2xl">{t.homepage.servicesSubtitle}</p>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 pt-4">
      {t.homepage.serviceCards.map(card => (
        <ServiceCard title={card.title} description={card.description} href={card.href} />
      ))}
    </div>
  </section>

  <div class="text-center py-8">
    <a href={t.bookingUrl}
      target="_blank" rel="noopener noreferrer"
      class="inline-block bg-blue-600 text-white rounded-full px-6 py-3 font-medium text-lg hover:bg-blue-700 transition-all duration-200 min-h-[48px] touch-manipulation">
      {t.homepage.midCta}
    </a>
  </div>

  <Testimonials />

  <div class="text-center py-8">
    <a href={t.bookingUrl}
      target="_blank" rel="noopener noreferrer"
      class="inline-block bg-blue-600 text-white rounded-full px-6 py-3 font-medium text-lg hover:bg-blue-700 transition-all duration-200 min-h-[48px] touch-manipulation">
      {t.hero.ctaButton}
    </a>
  </div>

  <Impacts />
  <Infrastructure />

  <ProcessSteps
    eyebrow={t.processSteps.eyebrow}
    title={t.processSteps.title}
    steps={t.processSteps.steps}
  />

  <!-- Neueste Blogbeiträge -->
  <section class="px-4 md:px-20 py-20 md:py-32 bg-gray-50">
    <div class="max-w-7xl mx-auto space-y-8">
      <span class="text-orange-500 font-semibold tracking-[0.2em] text-sm uppercase block">{t.homepage.insightsEyebrow}</span>
      <h2 class="text-3xl md:text-5xl font-bold">{t.homepage.insightsTitle}</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {latestPosts.map(post => (
          <BlogPostCard
            title={post.data.title}
            description={post.data.description}
            href={post.data.locale === 'de' ? `/de/ressourcen/blog/${post.slug}/` : `/resources/blog/${post.slug}/`}
            date={post.data.publishDate.toISOString()}
            category={post.data.category}
          />
        ))}
      </div>
      <div class="text-center pt-4">
        <a href={t.homepage.insightsLinkHref} class="text-blue-600 font-semibold text-lg hover:underline">{t.homepage.insightsLink}</a>
      </div>
    </div>
  </section>

  <FinalCTA />
  <Footer />
</Layout>
