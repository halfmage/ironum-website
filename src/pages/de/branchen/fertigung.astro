---
import Layout from '../../../layouts/Layout.astro';
import Navigation from '../../../components/Navigation.astro';
import PageHero from '../../../components/sections/PageHero.astro';
import FAQSection from '../../../components/sections/FAQSection.astro';
import FinalCTA from '../../../components/FinalCTA.astro';
import Footer from '../../../components/Footer.astro';

const breadcrumbs = [
  { label: 'Startseite', href: '/de/' },
  { label: 'Branchen', href: '/de/branchen/' },
  { label: 'Fertigung', href: '/de/branchen/fertigung/' },
];

const faqItems = [
  {
    question: 'Kann Ironum KI an unsere bestehenden ERP- und MES-Systeme angebunden werden?',
    answer: 'Ja. Wir nutzen n8n-Workflow-Automatisierung zur Integration mit SAP, Siemens und anderen gängigen ERP/MES-Plattformen. Unser API-First-Ansatz bedeutet, dass wir Ihre bestehenden Datenquellen anbinden, ohne Ihre Produktionssysteme zu ersetzen.',
  },
  {
    question: 'Wie funktioniert On-Premise-Deployment in Fabrikumgebungen?',
    answer: 'Wir deployen direkt auf Ihrer Fabrik-IT-Infrastruktur oder einem dedizierten Edge-Server. Dies stellt sicher, dass Produktionsdaten in Ihrem Netzwerk verbleiben, deutsche Datenschutzanforderungen erfüllt werden und minimale Latenz für Echtzeit-Anwendungen wie Qualitätsprüfung gewährleistet ist.',
  },
  {
    question: 'Welche Daten brauchen wir für den Einstieg in Predictive Maintenance?',
    answer: 'Mindestens historische Sensordaten Ihrer Maschinen (Vibration, Temperatur, Druck) und Wartungsprotokolle. Wir starten typischerweise mit einem Piloten auf 3-5 kritischen Maschinen, weisen den ROI innerhalb von 8-12 Wochen nach und skalieren dann über Ihre gesamte Produktion.',
  },
  {
    question: 'Ist die KI für Mittelständler geeignet?',
    answer: 'Absolut. Unsere Lösungen sind speziell für den deutschen Mittelstand konzipiert. Sie benötigen kein internes KI-Team. Laut Branchenstudien nennt rund ein Viertel der Fertigungsunternehmen den KI-Fachkräftemangel als Hindernis. Wir übernehmen das gesamte Deployment, Training und die laufende Optimierung.',
  },
  {
    question: 'Wie verhält sich das zur Technologieinitiative der Bundesregierung?',
    answer: 'Die milliardenschwere Technologieinitiative der Bundesregierung fördert die Industrie 4.0-Einführung. Unsere Lösungen entsprechen den Anforderungen der Förderprogramme und wir können Sie bei der Beantragung relevanter Technologieförderungen und Zuschüsse unterstützen.',
  },
];

const structuredData = [
  {
    "@type": "Service",
    "@id": "https://www.ironum.com/de/branchen/fertigung/#service",
    "name": "KI-Lösungen für die Fertigung - Industrie 4.0",
    "description": "KI-gestützte Predictive Maintenance, Qualitätsprüfung und Workflow-Automatisierung für den deutschen Mittelstand. Betrieb auf deutscher Infrastruktur.",
    "url": "https://www.ironum.com/de/branchen/fertigung/",
    "inLanguage": "de-DE",
    "provider": { "@id": "https://www.ironum.com/#organization" },
    "areaServed": { "@type": "Place", "name": "Deutschland, Österreich, Schweiz" },
    "serviceType": "KI-Infrastruktur für die Fertigung"
  },
  {
    "@type": "FAQPage",
    "mainEntity": faqItems.map(item => ({
      "@type": "Question",
      "name": item.question,
      "acceptedAnswer": { "@type": "Answer", "text": item.answer }
    }))
  }
];
---

<Layout
  title="KI für die Fertigung | Industrie 4.0 Lösungen | Ironum"
  description="KI-gestützte Predictive Maintenance, Qualitätsprüfung und Produktions-Workflow-Automatisierung. On-Premise oder Hetzner Cloud in Deutschland. Für den DACH-Mittelstand entwickelt."
  locale="de"
  breadcrumbs={breadcrumbs}
  structuredData={structuredData}
>
  <Navigation />
  <PageHero
    eyebrow="KI FÜR DIE FERTIGUNG"
    title="Industrie 4.0 KI, gehostet in Deutschland"
    subtitle="Der KI-Fertigungsmarkt wächst mit über 30% jährlichem Wachstum (Branchenschätzung). GenAI könnte die Profitabilität um bis zu 10% steigern. Setzen Sie produktionsreife KI auf Ihrem Shopfloor ein, ohne ein eigenes KI-Team aufbauen zu müssen."
  />

  <!-- Challenges Section -->
  <section class="px-4 md:px-20 py-20 md:py-32">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <span class="text-orange-500 font-semibold tracking-[0.2em] text-sm uppercase">Die Herausforderung</span>
        <h2 class="text-3xl md:text-5xl font-bold mt-4">Warum Fertigungsunternehmen mit KI kämpfen</h2>
        <p class="text-gray-500 text-lg font-semibold mt-4 max-w-2xl mx-auto">Eine Umfrage unter 247 Unternehmen zeigt drei kritische Barrieren, die die KI-Einführung in der Fertigung behindern.</p>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="border-2 border-gray-100 rounded-2xl p-8">
          <div class="w-12 h-12 bg-red-100 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2 1 3 3 3h10c2 0 3-1 3-3V7c0-2-1-3-3-3H7c-2 0-3 1-3 3z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 12h16" /></svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Datensilos in der Produktion</h3>
          <p class="text-gray-500">25% der Fertigungsunternehmen nennen fehlende Daten als Haupthindernis für KI. Produktionsdaten, die in getrennten ERP-, MES- und SCADA-Systemen eingeschlossen sind, machen KI-Deployment ohne Integrationskompetenz nahezu unmöglich.</p>
        </div>
        <div class="border-2 border-gray-100 rounded-2xl p-8">
          <div class="w-12 h-12 bg-red-100 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
          </div>
          <h3 class="text-xl font-bold mb-3">KI-Fachkräftemangel</h3>
          <p class="text-gray-500">Rund ein Viertel der Fertigungsunternehmen findet keine KI-Talente. Die Kluft zwischen Shopfloor-Expertise und KI-Engineering bedeutet, dass die meisten Mittelständler von den Vorteilen der Industrie 4.0 ausgeschlossen bleiben.</p>
        </div>
        <div class="border-2 border-gray-100 rounded-2xl p-8">
          <div class="w-12 h-12 bg-red-100 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Unzureichende IT-Infrastruktur</h3>
          <p class="text-gray-500">24% berichten über inadäquate IT-Systeme. Legacy-Infrastruktur kann moderne KI-Workloads nicht unterstützen, doch ein kompletter Umbau ist zu teuer und störend für die laufende Produktion.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Solutions Section -->
  <section class="px-4 md:px-20 py-20 md:py-32 bg-gray-50">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <span class="text-orange-500 font-semibold tracking-[0.2em] text-sm uppercase">Lösungen</span>
        <h2 class="text-3xl md:text-5xl font-bold mt-4">KI für Ihren Shopfloor</h2>
        <p class="text-gray-500 text-lg font-semibold mt-4 max-w-2xl mx-auto">Praxistaugliche KI-Lösungen, die sich in Ihre bestehenden Systeme integrieren. Kein Rip-and-Replace erforderlich.</p>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="bg-white border-2 border-gray-100 rounded-2xl p-8">
          <div class="w-12 h-12 bg-blue-100 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
          </div>
          <h3 class="text-xl font-bold mb-3">n8n Workflow-Automatisierung</h3>
          <p class="text-gray-500 mb-4">Verbinden Sie Ihre ERP-, MES- und Produktionssysteme mit intelligenten KI-Workflows. Automatisieren Sie Reporting, Auftragsbearbeitung und abteilungsübergreifende Datenflüsse ohne Custom Code.</p>
          <ul class="space-y-2 text-gray-500 text-sm">
            <li class="flex items-start gap-2"><svg class="w-4 h-4 text-blue-600 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>SAP-, Siemens- und Custom-System-Integration</li>
            <li class="flex items-start gap-2"><svg class="w-4 h-4 text-blue-600 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>Automatisiertes Produktions-Reporting und Alerts</li>
            <li class="flex items-start gap-2"><svg class="w-4 h-4 text-blue-600 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>Self-hosted: Produktionsdaten bleiben intern</li>
          </ul>
        </div>
        <div class="bg-white border-2 border-gray-100 rounded-2xl p-8">
          <div class="w-12 h-12 bg-blue-100 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>
          </div>
          <h3 class="text-xl font-bold mb-3">KI-Qualitätsprüfung</h3>
          <p class="text-gray-500 mb-4">KI-gestützte visuelle Inspektion und Fehlererkennung, integriert in Ihre Produktionslinie. Reduzieren Sie Ausschussraten, erkennen Sie Fehler früher und halten Sie gleichbleibende Qualitätsstandards.</p>
          <ul class="space-y-2 text-gray-500 text-sm">
            <li class="flex items-start gap-2"><svg class="w-4 h-4 text-blue-600 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>Echtzeit-Fehlererkennung in der Produktionslinie</li>
            <li class="flex items-start gap-2"><svg class="w-4 h-4 text-blue-600 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>Individuell trainiert auf Ihre Produktspezifikationen</li>
            <li class="flex items-start gap-2"><svg class="w-4 h-4 text-blue-600 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>Edge-Deployment für minimale Latenz</li>
          </ul>
        </div>
        <div class="bg-white border-2 border-gray-100 rounded-2xl p-8">
          <div class="w-12 h-12 bg-blue-100 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Predictive Maintenance Analytics</h3>
          <p class="text-gray-500 mb-4">Machine-Learning-Modelle, trainiert auf Ihren Sensordaten, um Ausfälle vorherzusagen, bevor sie auftreten. Reduzieren Sie ungeplante Stillstände, optimieren Sie Wartungspläne und verlängern Sie die Lebensdauer Ihrer Anlagen.</p>
          <ul class="space-y-2 text-gray-500 text-sm">
            <li class="flex items-start gap-2"><svg class="w-4 h-4 text-blue-600 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>Anomalieerkennung aus Vibrations- und Sensordaten</li>
            <li class="flex items-start gap-2"><svg class="w-4 h-4 text-blue-600 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>Optimierung der Wartungsplanung</li>
            <li class="flex items-start gap-2"><svg class="w-4 h-4 text-blue-600 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>ROI typischerweise innerhalb von 8-12 Wochen sichtbar</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats Section -->
  <section class="px-4 md:px-20 py-20 md:py-32">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <span class="text-orange-500 font-semibold tracking-[0.2em] text-sm uppercase">Marktchance</span>
        <h2 class="text-3xl md:text-5xl font-bold mt-4">Die Zahlen hinter Industrie 4.0</h2>
      </div>
      <div class="grid md:grid-cols-4 gap-8 text-center">
        <div class="border-2 border-gray-100 rounded-2xl p-8">
          <div class="text-blue-600 text-5xl font-bold mb-2">ca. 30%+</div>
          <p class="text-gray-500 text-lg font-semibold">Jährliches Wachstum im globalen KI-Fertigungsmarkt (Branchenschätzung)</p>
        </div>
        <div class="border-2 border-gray-100 rounded-2xl p-8">
          <div class="text-blue-600 text-5xl font-bold mb-2">bis 10%</div>
          <p class="text-gray-500 text-lg font-semibold">Potenzielle Profitabilitätssteigerung durch GenAI-Einführung (Branchenschätzung)</p>
        </div>
        <div class="border-2 border-gray-100 rounded-2xl p-8">
          <div class="text-blue-600 text-4xl font-bold mb-2">Mrd. &euro;</div>
          <p class="text-gray-500 text-lg font-semibold">Milliardenschwere Technologieinitiative der Bundesregierung</p>
        </div>
        <div class="border-2 border-gray-100 rounded-2xl p-8">
          <div class="text-blue-600 text-5xl font-bold mb-2">100%</div>
          <p class="text-gray-500 text-lg font-semibold">Produktionsdaten bleiben auf Ihrer Infrastruktur</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Related Services -->
  <section class="px-4 md:px-20 py-20 md:py-32 bg-gray-50">
    <div class="max-w-7xl mx-auto space-y-8">
      <span class="text-orange-500 font-semibold tracking-[0.2em] text-sm uppercase block">VERWANDTE SERVICES</span>
      <h2 class="text-3xl md:text-5xl font-bold">Lösungen, die Fertigungs-KI antreiben</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <a href="/de/dienstleistungen/workflow-automatisierung/" class="border-2 border-gray-100 rounded-2xl p-8 bg-white hover:border-blue-200 transition-colors group">
          <h3 class="text-xl font-bold mb-3">Workflow-Automatisierung</h3>
          <p class="text-gray-500 font-semibold mb-4">ERP-, MES- und Produktionssysteme mit intelligenten n8n-Workflows für automatisiertes Reporting und Datenflüsse verbinden.</p>
          <span class="text-blue-600 font-semibold inline-flex items-center gap-1 group-hover:gap-2 transition-all">Mehr erfahren <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg></span>
        </a>
        <a href="/de/dienstleistungen/enterprise-rag/" class="border-2 border-gray-100 rounded-2xl p-8 bg-white hover:border-blue-200 transition-colors group">
          <h3 class="text-xl font-bold mb-3">Enterprise RAG</h3>
          <p class="text-gray-500 font-semibold mb-4">Technische Dokumentation, Wartungsprotokolle und Schulungsmaterial mit KI-gestützter semantischer Suche durchsuchen.</p>
          <span class="text-blue-600 font-semibold inline-flex items-center gap-1 group-hover:gap-2 transition-all">Mehr erfahren <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg></span>
        </a>
        <a href="/de/dienstleistungen/ki-beratung/" class="border-2 border-gray-100 rounded-2xl p-8 bg-white hover:border-blue-200 transition-colors group">
          <h3 class="text-xl font-bold mb-3">KI-Beratung</h3>
          <p class="text-gray-500 font-semibold mb-4">Industrie 4.0 Readiness Assessments und KI-Strategie für Mittelständler auf dem Weg ins KI-Zeitalter.</p>
          <span class="text-blue-600 font-semibold inline-flex items-center gap-1 group-hover:gap-2 transition-all">Mehr erfahren <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg></span>
        </a>
      </div>
    </div>
  </section>

  <FAQSection items={faqItems} />
  <FinalCTA />
  <Footer />
</Layout>
