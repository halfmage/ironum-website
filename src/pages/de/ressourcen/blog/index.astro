---
import Layout from '../../../../layouts/Layout.astro';
import Navigation from '../../../../components/Navigation.astro';
import PageHero from '../../../../components/sections/PageHero.astro';
import BlogPostCard from '../../../../components/cards/BlogPostCard.astro';
import Footer from '../../../../components/Footer.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(post => !post.data.draft && post.data.locale === 'de')
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

const breadcrumbs = [
  { label: 'Startseite', href: '/de/' },
  { label: 'Ressourcen', href: '/de/ressourcen/' },
  { label: 'Blog', href: '/de/ressourcen/blog/' },
];
---

<Layout title="Blog | Ironum AI Core" description="Experteneinblicke zu DSGVO-konformer KI, EU AI Act Compliance, Enterprise RAG und Workflow-Automatisierung für den europäischen Mittelstand." locale="de" breadcrumbs={breadcrumbs}>
  <Navigation />
  <PageHero eyebrow="BLOG" title="KI-Insights für den Mittelstand" subtitle="Praxiswissen zu Compliance, Implementierung und Strategie." ctaLink="" />
  <section class="px-4 md:px-20 py-20 md:py-32 max-w-7xl mx-auto">
    {posts.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {posts.map(post => (
          <BlogPostCard
            title={post.data.title}
            description={post.data.description}
            href={`/de/ressourcen/blog/${post.slug}/`}
            date={post.data.publishDate.toISOString()}
            category={post.data.category}
          />
        ))}
      </div>
    ) : (
      <p class="text-gray-500 text-lg text-center">Neue Artikel erscheinen in Kürze. Schauen Sie bald wieder vorbei.</p>
    )}
  </section>
  <Footer />
</Layout>
